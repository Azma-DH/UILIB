	})
	new("TextLabel", {
		Text = title, TextSize = 14, Font = Enum.Font.GothamBold,
		TextColor3 = C.TxtHi, BackgroundTransparency = 1,
		Size = UDim2.new(0,220,0,20), Position = UDim2.new(0,14,0,6),
		TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 3, Parent = Top,
	})
	new("TextLabel", {
		Text = desc, TextSize = 11, Font = Enum.Font.Gotham,
