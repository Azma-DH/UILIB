local function Notify(title, desc, duration)
    duration = duration or 4

    local wrapper = New("Frame", {
        Size               = UDim2.new(1, 0, 0, 0),
        BackgroundTransparency = 1,
        AutomaticSize      = Enum.AutomaticSize.Y,
        Parent             = NotifHolder,
    })

    local box = New("Frame", {
        Size               = UDim2.new(1, 0, 0, 0),
        Position           = UDim2.new(1, 20, 0, 0),
        BackgroundColor3   = T.NotifBg,
        AutomaticSize      = Enum.AutomaticSize.Y,
        ClipsDescendants   = false,
        Parent             = wrapper,
    }, {
        Corner(8),
        Stroke(T.Accent, 1, 0.3),
        Padding(10, 10, 12, 12),
        New("UIListLayout", { Padding = UDim.new(0, 3), SortOrder = Enum.SortOrder.LayoutOrder }),
    })

    -- Accent top bar
    New("Frame", {
        Size             = UDim2.new(1, 0, 0, 2),
        BackgroundColor3 = T.Accent,
        BorderSizePixel  = 0,
        LayoutOrder      = 0,
        Parent           = box,
    }, { Corner(2) })

    local titleLabel = New("TextLabel", {
        Text               = title or "Notification",
        TextSize           = 13,
        Font               = Enum.Font.GothamBold,
        TextColor3         = T.TextPrimary,
        BackgroundTransparency = 1,
        Size               = UDim2.new(1, 0, 0, 16),
        TextXAlignment     = Enum.TextXAlignment.Left,
        LayoutOrder        = 1,
        Parent             = box,
    })

    local descLabel = New("TextLabel", {
        Text               = desc or "",
        TextSize           = 12,
        Font               = Enum.Font.Gotham,
        TextColor3         = T.TextSecondary,
        BackgroundTransparency = 1,
        Size               = UDim2.new(1, 0, 0, 0),
        AutomaticSize      = Enum.AutomaticSize.Y,
        TextXAlignment     = Enum.TextXAlignment.Left,
        TextWrapped        = true,
        LayoutOrder        = 2,
        Parent             = box,
    })

    -- Slide in
    Tween(box, { Position = UDim2.new(0, 0, 0, 0) }, 0.4, Enum.EasingStyle.Quint)

    task.delay(duration - 0.5, function()
        Tween(box, { BackgroundTransparency = 0.5 }, 0.3)
        Tween(titleLabel, { TextTransparency = 0.5 }, 0.3)
        Tween(descLabel,  { TextTransparency = 0.6 }, 0.3)
        task.wait(0.3)
        Tween(box, { Position = UDim2.new(1, 20, 0, 0) }, 0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
        task.wait(0.45)
        wrapper:Destroy()
    end)
end

DaggerLib.Notify = Notify

