	function Win:Tab(cfg)
		cfg = cfg or {}
		local name = cfg.Title or "Tab"

		local TabBtn = new("TextButton", {
			Size = UDim2.new(1,0,0,30), BackgroundColor3 = C.Sidebar,
			AutoButtonColor = false, Text = "", BorderSizePixel = 0,
			Parent = Sidebar,
		}, { corner(6) })

		local AccBar = new("Frame", {
			Size = UDim2.new(0,3,0.55,0), Position = UDim2.new(0,0,0.225,0),
			BackgroundColor3 = C.Accent, BorderSizePixel = 0,
			Visible = false, Parent = TabBtn,
		}, { corner(2) })

		local TabLabel = new("TextLabel", {
			Text = name, TextSize = 12, Font = Enum.Font.GothamSemibold,
			TextColor3 = C.TxtLo, BackgroundTransparency = 1,
			Size = UDim2.new(1,-12,1,0), Position = UDim2.new(0,12,0,0),
			TextXAlignment = Enum.TextXAlignment.Left, Parent = TabBtn,
		})

		local Page = new("Frame", {
			Size = UDim2.new(1,0,0,0), AutomaticSize = Enum.AutomaticSize.Y,
			BackgroundTransparency = 1, Visible = false, Parent = ContentScroll,
		}, { list(6) })

		local entry = {btn=TabBtn,label=TabLabel,bar=AccBar,page=Page}
		table.insert(allTabs, entry)

		local function activate()
			deactivateAll()
			Page.Visible = true
			tween(TabBtn,   {BackgroundColor3=C.ElemHov},0.18)
			tween(TabLabel, {TextColor3=C.TxtHi},0.18)
			AccBar.Visible = true
			activeTab = entry
			ContentScroll.CanvasPosition = Vector2.zero
		end

		if firstTab then firstTab = false activate() end

		TabBtn.MouseButton1Click:Connect(activate)
		TabBtn.MouseEnter:Connect(function()
			if activeTab ~= entry then tween(TabBtn,{BackgroundColor3=C.Elem},0.12) end
		end)
		TabBtn.MouseLeave:Connect(function()
			if activeTab ~= entry then tween(TabBtn,{BackgroundColor3=C.Sidebar},0.12) end
		end)

		local Tab = {}

		local function base(h)
			return new("Frame", {
				Size = UDim2.new(1,0,0,h or 36),
				BackgroundColor3 = C.Elem, BorderSizePixel = 0,
				ClipsDescendants = false, Parent = Page,
			}, { corner(7), stroke(C.Stroke,1,0.6) })
		end

