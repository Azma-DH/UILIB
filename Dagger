				Text=n, TextSize=10, Font=Enum.Font.GothamBold, TextColor3=C.Accent,
				BackgroundTransparency=1, Size=UDim2.new(0,0,1,0), AutomaticSize=Enum.AutomaticSize.X,
				TextXAlignment=Enum.TextXAlignment.Left, Parent=row,
			})
			new("Frame",{
				AnchorPoint=Vector2.new(0,0.5),
				Size=UDim2.new(1,-8,0,1), Position=UDim2.new(0,8,0.5,0),
				BackgroundColor3=C.Div, BorderSizePixel=0, Parent=row,
			})
		end

		function Tab:Button(cfg)
			cfg = cfg or {}
			local bName = cfg.Title    or "Button"
			local bDesc = cfg.Desc     or ""
			local bCb   = cfg.Callback or function() end
			local h = bDesc~="" and 48 or 34
			local f = base(h)
