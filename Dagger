                Parent           = Frame,
            }, {
                Corner(7),
                Stroke(T.Stroke, 1, 0.5),
                ListLayout(2),
                Padding(4, 4, 4, 4),
            })

            local function BuildList()
                for _, v in ipairs(ListContainer:GetChildren()) do
                    if v:IsA("TextButton") then v:Destroy() end
                end
                for _, opt in ipairs(ddList) do
                    local Opt = New("TextButton", {
                        Text               = opt,
                        TextSize           = 12,
                        Font               = Enum.Font.Gotham,
                        TextColor3         = opt == selected and T.AccentGlow or T.TextSecondary,
                        BackgroundColor3   = opt == selected and T.AccentDark or T.Element,
                        Size               = UDim2.new(1, 0, 0, itemH - 4),
                        AutoButtonColor    = false,
                        TextXAlignment     = Enum.TextXAlignment.Left,
                        ZIndex             = 11,
                        Parent             = ListContainer,
                    }, {
                        Corner(5),
                        Padding(0, 0, 8, 0),
                    })
                    Opt.MouseButton1Click:Connect(function()
                        selected = opt
                        SelectedLabel.Text = opt
                        BuildList()
                        task.spawn(ddCallback, opt)
                    end)
                    Opt.MouseEnter:Connect(function()
                        if opt ~= selected then
                            TweenQuad(Opt, { BackgroundColor3 = T.ElementPress })
                            TweenQuad(Opt, { TextColor3 = T.TextPrimary })
                        end
                    end)
                    Opt.MouseLeave:Connect(function()
                        if opt ~= selected then
                            TweenQuad(Opt, { BackgroundColor3 = T.Element })
                            TweenQuad(Opt, { TextColor3 = T.TextSecondary })
                        end
                    end)
                end
            end

            BuildList()

            local Click = New("TextButton", {
                Size               = UDim2.new(1, 0, 0, baseH),
                BackgroundTransparency = 1,
                Text               = "",
                AutoButtonColor    = false,
                Parent             = Frame,
            })

            Click.MouseButton1Click:Connect(function()
                open = not open
                local listCount = #ddList
                local targetH   = open and math.min(listCount * itemH + 8, 150) or 0
                Tween(ListContainer, { Size = UDim2.new(1, 0, 0, targetH) }, 0.2)
                Tween(Frame, { Size = UDim2.new(1, 0, 0, baseH + (open and targetH + 4 or 0)) }, 0.2)
                Tween(Arrow, { Rotation = open and 270 or 90 }, 0.2)
            end)

            Click.MouseEnter:Connect(function()
                Tween(Frame, { BackgroundColor3 = T.ElementHover }, 0.15)
            end)
            Click.MouseLeave:Connect(function()
                Tween(Frame, { BackgroundColor3 = T.Element }, 0.15)
            end)

            local DropObj = {}
            function DropObj:UpdateList(newList)
                ddList = newList
                BuildList()
            end
            function DropObj:SetValue(v)
                selected = v
                SelectedLabel.Text = v ~= "" and v or "Select..."
                BuildList()
            end
            function DropObj:GetValue() return selected end
            DropObj.Value = selected
            return DropObj
        end

        -- тФАтФА Label / Code Display тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
        function Tab:Code(cConfig)
            cConfig       = cConfig or {}
            local cTitle  = cConfig.Title or "Info"
            local cText   = cConfig.Code  or ""

            local Frame = ElemBase(0)
            Frame.AutomaticSize = Enum.AutomaticSize.Y
            Frame.ClipsDescendants = false

            New("TextLabel", {
                Text               = cTitle,
                TextSize           = 10,
                Font               = Enum.Font.GothamBold,
                TextColor3         = T.Accent,
                BackgroundTransparency = 1,
                Size               = UDim2.new(1, -12, 0, 14),
                Position           = UDim2.new(0, 12, 0, 6),
                TextXAlignment     = Enum.TextXAlignment.Left,
                Parent             = Frame,
            })

            local ContentLabel = New("TextLabel", {
                Text               = cText,
                TextSize           = 12,
                Font               = Enum.Font.Code,
                TextColor3         = T.TextSecondary,
                BackgroundTransparency = 1,
                Size               = UDim2.new(1, -24, 0, 0),
                Position           = UDim2.new(0, 12, 0, 22),
                AutomaticSize      = Enum.AutomaticSize.Y,
                TextXAlignment     = Enum.TextXAlignment.Left,
                TextWrapped        = true,
                Parent             = Frame,
            })

            -- Bottom padding spacer
            New("Frame", {
                Size             = UDim2.new(1, 0, 0, 8),
                Position         = UDim2.new(0, 0, 1, 0),
                BackgroundTransparency = 1,
                Parent           = Frame,
            })

            local CodeObj = {}
            function CodeObj:SetCode(v)
                ContentLabel.Text = tostring(v)
            end
            return CodeObj
        end

        -- тФАтФА Label (simple text) тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
        function Tab:Label(lConfig)
            lConfig      = lConfig or {}
            local lText  = lConfig.Text or ""

            local Frame = New("Frame", {
                Size             = UDim2.new(1, 0, 0, 24),
                BackgroundTransparency = 1,
                Parent           = TabContent,
            })

            local Lbl = New("TextLabel", {
                Text               = lText,
                TextSize           = 12,
                Font               = Enum.Font.Gotham,
                TextColor3         = T.TextSecondary,
                BackgroundTransparency = 1,
                Size               = UDim2.new(1, -12, 1, 0),
                Position           = UDim2.new(0, 12, 0, 0),
                TextXAlignment     = Enum.TextXAlignment.Left,
                TextWrapped        = true,
                Parent             = Frame,
            })

            local LblObj = {}
            function LblObj:Set(v) Lbl.Text = tostring(v) end
            return LblObj
        end

        -- тФАтФА Line separator тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
        function Tab:Line()
            New("Frame", {
                Size             = UDim2.new(1, -12, 0, 1),
                Position         = UDim2.new(0, 6, 0, 0),
                BackgroundColor3 = T.Divider,
                BorderSizePixel  = 0,
                Parent           = TabContent,
            })
        end

        return Tab
    end

    -- Window-level Notify wrapper
    function WindowObj:Notify(nConfig)
        nConfig = nConfig or {}
        Notify(nConfig.Title, nConfig.Desc, nConfig.Time)
    end

    -- Window-level Line (cosmetic only, between sidebar sections)
    function WindowObj:Line() end

    return WindowObj
end

-- тФАтФАтФА Return тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
return DaggerLib
