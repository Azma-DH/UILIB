local function Notify(title, body, dur)
	dur = math.max(dur or 4, 1.5)
	local wrap = mk("Frame",{Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundTransparency=1,Parent=NH})
	local box  = mk("Frame",{
		Size=UDim2.new(1,0,0,0), Position=UDim2.new(1,8,0,0),
		AutomaticSize=Enum.AutomaticSize.Y, BackgroundColor3=C.NotifBg,
		BorderSizePixel=0, Parent=wrap,
	},{rnd(8),str(C.Accent,1,0.4),pdg(12,12,14,14),lst(4)})
	-- glow left bar
	mk("Frame",{Size=UDim2.new(0,2,1,-2),Position=UDim2.new(0,0,0,1),
		BackgroundColor3=C.AccentHi,BorderSizePixel=0,ZIndex=2,Parent=box},{rnd(2)})
	local tl = mk("TextLabel",{Text=title or "",TextSize=13,Font=Enum.Font.GothamBold,
		TextColor3=C.TxtA,BackgroundTransparency=1,Size=UDim2.new(1,0,0,15),
		TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=0,Parent=box})
	local dl = mk("TextLabel",{Text=body or "",TextSize=11,Font=Enum.Font.Gotham,
		TextColor3=C.TxtB,BackgroundTransparency=1,Size=UDim2.new(1,0,0,0),
		AutomaticSize=Enum.AutomaticSize.Y,TextXAlignment=Enum.TextXAlignment.Left,
		TextWrapped=true,LayoutOrder=1,Parent=box})
	tw(box,{Position=UDim2.new(0,0,0,0)},0.3,Enum.EasingStyle.Quint)
	task.delay(dur-0.5,function()
		tw(box,{BackgroundTransparency=0.6},0.25)
		tw(tl,{TextTransparency=0.6},0.25)
		tw(dl,{TextTransparency=0.7},0.25)
		task.wait(0.25)
		tw(box,{Position=UDim2.new(1,8,0,0)},0.3,Enum.EasingStyle.Quint,Enum.EasingDirection.In)
		task.wait(0.35)
		wrap:Destroy()
	end)
end

-- ─── Drag ────────────────────────────────────────────────────────────────────
local function drag(handle, frame)
	local on,inp,mp,fp=false
	handle.InputBegan:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseButton1 then
			on=true mp=i.Position fp=frame.Position
			i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then on=false end end)
		end
	end)
	handle.InputChanged:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseMovement then inp=i end
	end)
	UIS.InputChanged:Connect(function(i)
		if i==inp and on then
			local d=i.Position-mp
			tw(frame,{Position=UDim2.new(fp.X.Scale,fp.X.Offset+d.X,fp.Y.Scale,fp.Y.Offset+d.Y)},0.08,Enum.EasingStyle.Linear)
		end
	end)
end

