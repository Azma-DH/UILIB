local function Notify(title, desc, duration)
	duration = math.max(duration or 4, 1.5)
	local wrap = new("Frame", {
		Size              = UDim2.new(1, 0, 0, 0),
		AutomaticSize     = Enum.AutomaticSize.Y,
		BackgroundTransparency = 1,
		Parent            = NotifFrame,
	})
	local box = new("Frame", {
		Size             = UDim2.new(1, 0, 0, 0),
		Position         = UDim2.new(1, 10, 0, 0),
		AutomaticSize    = Enum.AutomaticSize.Y,
		BackgroundColor3 = C.Notif,
		BorderSizePixel  = 0,
		Parent           = wrap,
	}, {
		corner(8),
		stroke(C.Accent, 1, 0.35),
		pad(10, 10, 12, 12),
		list(4),
	})
	new("Frame", {
		Size             = UDim2.new(1, 0, 0, 2),
		BackgroundColor3 = C.Accent,
		BorderSizePixel  = 0,
		LayoutOrder      = 0,
		Parent           = box,
	}, { corner(2) })
	local tlbl = new("TextLabel", {
		Text               = title or "",
		TextSize           = 13,
		Font               = Enum.Font.GothamBold,
		TextColor3         = C.TxtHi,
		BackgroundTransparency = 1,
		Size               = UDim2.new(1, 0, 0, 16),
		TextXAlignment     = Enum.TextXAlignment.Left,
		LayoutOrder        = 1,
		Parent             = box,
	})
	local dlbl = new("TextLabel", {
		Text               = desc or "",
		TextSize           = 12,
		Font               = Enum.Font.Gotham,
		TextColor3         = C.TxtMid,
		BackgroundTransparency = 1,
		Size               = UDim2.new(1, 0, 0, 0),
		AutomaticSize      = Enum.AutomaticSize.Y,
		TextXAlignment     = Enum.TextXAlignment.Left,
		TextWrapped        = true,
		LayoutOrder        = 2,
		Parent             = box,
	})
	tween(box, { Position = UDim2.new(0, 0, 0, 0) }, 0.35, Enum.EasingStyle.Quint)
	task.delay(duration - 0.6, function()
		tween(box,  { BackgroundTransparency = 0.55 }, 0.25)
		tween(tlbl, { TextTransparency = 0.55 }, 0.25)
		tween(dlbl, { TextTransparency = 0.65 }, 0.25)
		task.wait(0.25)
		tween(box, { Position = UDim2.new(1, 10, 0, 0) }, 0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
		task.wait(0.4)
		wrap:Destroy()
	end)
end

local function makeDraggable(handle, frame)
	local drag, dragInp, mPos, fPos = false
	handle.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then
			drag = true
			mPos = i.Position
			fPos = frame.Position
			i.Changed:Connect(function()
				if i.UserInputState == Enum.UserInputState.End then drag = false end
			end)
		end
	end)
	handle.InputChanged:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseMovement then dragInp = i end
	end)
	UIS.InputChanged:Connect(function(i)
		if i == dragInp and drag then
			local d = i.Position - mPos
			tween(frame, {
				Position = UDim2.new(fPos.X.Scale, fPos.X.Offset + d.X, fPos.Y.Scale, fPos.Y.Offset + d.Y)
			}, 0.1, Enum.EasingStyle.Linear)
		end
	end)
end

