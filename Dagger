local DaggerLib = {}
DaggerLib.Notify = Notify

function DaggerLib:Window(cfg)
    cfg = cfg or {}
    local title    = cfg.Title    or "Hub"
    local subtitle = cfg.Subtitle or ""
    local key      = cfg.Key      or Enum.KeyCode.RightControl

    -- Window dimensions — compact
    local W, H   = 480, 360
    local SIDEBAR = 120
    local TOPBAR  = 34

    local Win = {}
    Win.Notify = Notify

    -- ── Shadow layer (simple dark frame slightly larger) ──────────────────
    local Shadow = new("Frame",{
        Size=UDim2.fromOffset(W+8,H+8),
        Position=UDim2.new(0.5,-(W+8)/2,0.5,-(H+8)/2),
        BackgroundColor3=Color3.fromRGB(0,0,0),
        BackgroundTransparency=0.6,
        BorderSizePixel=0, Parent=Gui,
    },{rnd(14)})

    -- ── Main window ───────────────────────────────────────────────────────
    local Main = new("Frame",{
        Size=UDim2.fromOffset(W,H),
        Position=UDim2.new(0.5,-W/2,0.5,-H/2),
        BackgroundColor3=D.s1,
        BorderSizePixel=0, ClipsDescendants=true,
        Parent=Gui,
    },{rnd(10), uist(D.b1,1,0)})

    -- Keep shadow aligned to window
    task.spawn(function()
        while Main.Parent do
            Shadow.Position=UDim2.fromOffset(Main.Position.X.Offset-4,Main.Position.Y.Offset-4)
            task.wait()
        end
    end)

    -- ── Topbar ────────────────────────────────────────────────────────────
    local Top = new("Frame",{
        Size=UDim2.new(1,0,0,TOPBAR),
        BackgroundColor3=D.s2, BorderSizePixel=0, ZIndex=2, Parent=Main,
    })
    -- Square off topbar bottom corners
    new("Frame",{Size=UDim2.new(1,0,0,10),Position=UDim2.new(0,0,1,-10),
        BackgroundColor3=D.s2,BorderSizePixel=0,ZIndex=2,Parent=Top})
    -- Topbar bottom border
    new("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=D.b1,BorderSizePixel=0,ZIndex=3,Parent=Top})
    rnd(10):Clone().Parent=Top

    -- Title
    new("TextLabel",{
        Text=title,TextSize=13,Font=Enum.Font.GothamBold,
        TextColor3=D.t1,BackgroundTransparency=1,
        Size=UDim2.new(0,180,1,0),Position=UDim2.new(0,12,0,0),
        TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=Top,
    })
    -- Subtitle badge
    if subtitle~="" then
        local badge=new("Frame",{
            Size=UDim2.new(0,0,0,16),AutomaticSize=Enum.AutomaticSize.X,
            Position=UDim2.new(0,12+#title*7.5,0.5,-8),
            BackgroundColor3=D.accB,BorderSizePixel=0,ZIndex=3,Parent=Top,
        },{rnd(4),upd(0,0,5,5)})
        new("TextLabel",{
            Text=subtitle,TextSize=10,Font=Enum.Font.GothamBold,
            TextColor3=D.acc,BackgroundTransparency=1,
            Size=UDim2.new(0,0,1,0),AutomaticSize=Enum.AutomaticSize.X,
            TextXAlignment=Enum.TextXAlignment.Left,ZIndex=4,Parent=badge,
        })
    end

    -- Window control buttons
    local function mkCtrlBtn(sym, xOff)
        local b = new("TextButton",{
            Text=sym,TextSize=10,Font=Enum.Font.GothamBold,
            TextColor3=D.t3,BackgroundColor3=D.s3,
            Size=UDim2.fromOffset(20,20),
            Position=UDim2.new(1,xOff,0.5,-10),
            AutoButtonColor=false,BorderSizePixel=0,ZIndex=4,Parent=Top,
        },{rnd(5)})
        b.MouseEnter:Connect(function() tw(b,{BackgroundColor3=D.s3h,TextColor3=D.t1},0.12) end)
        b.MouseLeave:Connect(function() tw(b,{BackgroundColor3=D.s3,TextColor3=D.t3},0.12) end)
        return b
    end
    local CloseB = mkCtrlBtn("✕",-28)
    local MinB   = mkCtrlBtn("─",-52)

    makeDraggable(Top, Main)
    -- Also move shadow on drag
    Main:GetPropertyChangedSignal("Position"):Connect(function()
        Shadow.Position=UDim2.fromOffset(Main.Position.X.Offset-4,Main.Position.Y.Offset-4)
    end)

    local minimised=false
    CloseB.MouseButton1Click:Connect(function()
        tw(Main,{Size=UDim2.fromOffset(W,0)},0.18,Enum.EasingStyle.Quint,Enum.EasingDirection.In)
        tw(Shadow,{Size=UDim2.fromOffset(W+8,0)},0.18,Enum.EasingStyle.Quint,Enum.EasingDirection.In)
        task.wait(0.2) Main.Visible=false Shadow.Visible=false
        Notify({Title="Hidden",Desc="Press "..key.Name.." to reopen.",Duration=3})
    end)
    MinB.MouseButton1Click:Connect(function()
        minimised=not minimised
        local h=minimised and TOPBAR or H
        tw(Main,  {Size=UDim2.fromOffset(W,h)},0.22)
        tw(Shadow,{Size=UDim2.fromOffset(W+8,h+8)},0.22)
    end)
    UIS.InputBegan:Connect(function(i,gp)
        if gp then return end
        if i.KeyCode==key then
            Main.Visible=not Main.Visible
            Shadow.Visible=Main.Visible
            if Main.Visible and minimised then
                minimised=false
                tw(Main,  {Size=UDim2.fromOffset(W,H)},0.22)
                tw(Shadow,{Size=UDim2.fromOffset(W+8,H+8)},0.22)
            end
        end
    end)

    -- ── Sidebar ───────────────────────────────────────────────────────────
    local Sidebar = new("Frame",{
        Size=UDim2.new(0,SIDEBAR,1,-TOPBAR),
        Position=UDim2.new(0,0,0,TOPBAR),
        BackgroundColor3=D.s2, BorderSizePixel=0, Parent=Main,
    },{upd(6,6,6,6),ull(2)})
    -- Right border
    new("Frame",{Size=UDim2.new(0,1,1,0),Position=UDim2.new(1,-1,0,0),
        BackgroundColor3=D.b1,BorderSizePixel=0,Parent=Sidebar})

    -- ── Content scroll ────────────────────────────────────────────────────
    local Scroll = new("ScrollingFrame",{
        Size=UDim2.new(1,-SIDEBAR,1,-TOPBAR),
        Position=UDim2.new(0,SIDEBAR,0,TOPBAR),
        BackgroundColor3=D.s1, BorderSizePixel=0,
        ScrollBarThickness=2, ScrollBarImageColor3=D.accS,
        ScrollingDirection=Enum.ScrollingDirection.Y,
        CanvasSize=UDim2.new(0,0,0,0),
        Parent=Main,
    },{upd(6,6,0,0),ull(0)})

    local scrollLayout=Scroll:FindFirstChildOfClass("UIListLayout")
    scrollLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        Scroll.CanvasSize=UDim2.new(0,0,0,scrollLayout.AbsoluteContentSize.Y+12)
    end)

    -- ── Tab system ────────────────────────────────────────────────────────
    local tabs={} local firstTab=true local activeTab=nil

    local function deactivateAll()
        for _,t in ipairs(tabs) do
            t.page.Visible=false
            tw(t.pill,{BackgroundTransparency=1},0.15)
            tw(t.lbl, {TextColor3=D.t3},0.15)
        end
    end

    function Win:Tab(tcfg)
        tcfg = tcfg or {}
        local tname = tcfg.Title or "Tab"
        local ticon = tcfg.Icon  or ""

        -- ── Sidebar tab button ────────────────────────────────────────────
        local btn = new("TextButton",{
            Size=UDim2.new(1,0,0,28),
            BackgroundTransparency=1, Text="",
            AutoButtonColor=false, BorderSizePixel=0,
            Parent=Sidebar,
        },{rnd(6)})

        -- Pill background (hidden by default, accent when active)
        local pill = new("Frame",{
            Size=UDim2.new(1,0,1,0),
            BackgroundColor3=D.tabBg,
            BackgroundTransparency=1,
            BorderSizePixel=0, Parent=btn,
        },{rnd(6)})

        -- Content row inside tab button
        local row = new("Frame",{
            Size=UDim2.new(1,0,1,0),
            BackgroundTransparency=1, Parent=btn,
        },{upd(0,0,8,4)})

        -- Icon (if any)
        local xOff=0
        if ticon~="" then
            new("ImageLabel",{
                Image=ticon, Size=UDim2.fromOffset(14,14),
                Position=UDim2.new(0,0,0.5,-7),
                BackgroundTransparency=1,
                ImageColor3=D.t3, Parent=row,
            })
            xOff=18
        end

        local lbl = new("TextLabel",{
            Text=tname, TextSize=11, Font=Enum.Font.GothamSemibold,
            TextColor3=D.t3, BackgroundTransparency=1,
            Size=UDim2.new(1,-xOff,1,0),
            Position=UDim2.new(0,xOff,0,0),
            TextXAlignment=Enum.TextXAlignment.Left,
            Parent=row,
        })

        -- Active indicator bar on left edge
        local bar = new("Frame",{
            Size=UDim2.new(0,2,0.55,0),
            Position=UDim2.new(0,0,0.225,0),
            BackgroundColor3=D.acc,
            BackgroundTransparency=1,
            BorderSizePixel=0, Parent=btn,
        },{rnd(1)})

        -- Page
        local page = new("Frame",{
            Size=UDim2.new(1,0,0,0),
            AutomaticSize=Enum.AutomaticSize.Y,
            BackgroundTransparency=1,
            Visible=false, Parent=Scroll,
        },{ull(0)})

        local entry={btn=btn,pill=pill,lbl=lbl,bar=bar,page=page}
        table.insert(tabs,entry)

        local function activate()
            deactivateAll()
            page.Visible=true
            tw(pill,{BackgroundTransparency=0},0.15)
            tw(lbl, {TextColor3=D.tabText},0.15)
            tw(bar, {BackgroundTransparency=0},0.15)
            activeTab=entry
            Scroll.CanvasPosition=Vector2.zero
        end

        btn.MouseButton1Click:Connect(activate)
        btn.MouseEnter:Connect(function()
            if activeTab~=entry then tw(pill,{BackgroundTransparency=0.85},0.12) end
        end)
        btn.MouseLeave:Connect(function()
            if activeTab~=entry then tw(pill,{BackgroundTransparency=1},0.12) end
        end)

        if firstTab then firstTab=false activate() end

        -- ── Element builders ──────────────────────────────────────────────
        local Tab={}

        -- Base element row — compact, 32px default
        local function mkRow(h, autoSize)
            local f=new("Frame",{
                Size=UDim2.new(1,0,0,h or 32),
                BackgroundColor3=D.s3,
                BorderSizePixel=0,
                ClipsDescendants=false,
                AutomaticSize=autoSize and Enum.AutomaticSize.Y or Enum.AutomaticSize.None,
                Parent=page,
            },{rnd(6), uist(D.b1,1,0.5)})
            return f
        end

        -- ── SECTION header ────────────────────────────────────────────────
        function Tab:Section(text)
            local wrap=new("Frame",{
                Size=UDim2.new(1,0,0,22),
                BackgroundTransparency=1, Parent=page,
            })
            -- Accent line
            new("Frame",{
                Size=UDim2.new(0,2,0.5,0),
                Position=UDim2.new(0,8,0.25,0),
                BackgroundColor3=D.acc,
                BorderSizePixel=0, Parent=wrap,
            },{rnd(1)})
            new("TextLabel",{
                Text=(text or ""):upper(),
                TextSize=9, Font=Enum.Font.GothamBold,
                TextColor3=D.t3,
                BackgroundTransparency=1,
                Size=UDim2.new(1,-16,1,0),
                Position=UDim2.new(0,14,0,0),
                TextXAlignment=Enum.TextXAlignment.Left,
                Parent=wrap,
            })
        end

        -- ── TOGGLE ────────────────────────────────────────────────────────
        function Tab:Toggle(cfg)
            cfg=cfg or {}
            local title=cfg.Title or "Toggle"
            local desc =cfg.Desc  or ""
            local def  =cfg.Default; if def==nil then def=false end
            local cb   =cfg.Callback or function()end

            local on=def
            local h=desc~="" and 46 or 32
            local f=mkRow(h)

            -- Title
            new("TextLabel",{
                Text=title, TextSize=12, Font=Enum.Font.GothamSemibold,
                TextColor3=D.t1, BackgroundTransparency=1,
                Size=UDim2.new(1,-58,0,16),
                Position=UDim2.new(0,10,0,desc~="" and 6 or 8),
                TextXAlignment=Enum.TextXAlignment.Left, Parent=f,
            })
            if desc~="" then
                new("TextLabel",{
                    Text=desc, TextSize=10, Font=Enum.Font.Gotham,
                    TextColor3=D.t3, BackgroundTransparency=1,
                    Size=UDim2.new(1,-58,0,13),
                    Position=UDim2.new(0,10,0,24),
                    TextXAlignment=Enum.TextXAlignment.Left,
                    TextWrapped=true, Parent=f,
                })
            end

            -- Toggle pill — compact 32×18
            local track=new("Frame",{
                Size=UDim2.fromOffset(32,18),
                Position=UDim2.new(1,-42,0.5,-9),
                BackgroundColor3=on and D.togOn or D.togOff,
                BorderSizePixel=0, Parent=f,
            },{rnd(9)})
            local thumb=new("Frame",{
                Size=UDim2.fromOffset(12,12),
                Position=on and UDim2.fromOffset(17,3) or UDim2.fromOffset(3,3),
                BackgroundColor3=on and D.thumbOn or D.thumbOff,
                BorderSizePixel=0, Parent=track,
            },{rnd(6)})

            local function setState(v,silent)
                on=v
                if v then
                    tw(track,{BackgroundColor3=D.togOn},0.18)
                    tw(thumb,{Position=UDim2.fromOffset(17,3),BackgroundColor3=D.thumbOn},0.18)
                else
                    tw(track,{BackgroundColor3=D.togOff},0.18)
                    tw(thumb,{Position=UDim2.fromOffset(3,3),BackgroundColor3=D.thumbOff},0.18)
                end
                if not silent then task.spawn(cb,v) end
            end
            setState(def,true)

            local cl=new("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false,Parent=f})
            cl.MouseEnter:Connect(function()    tw(f,{BackgroundColor3=D.s3h},0.1) end)
            cl.MouseLeave:Connect(function()    tw(f,{BackgroundColor3=D.s3},0.1) end)
            cl.MouseButton1Down:Connect(function() tw(f,{BackgroundColor3=D.s3p},0.07) end)
            cl.MouseButton1Up:Connect(function()
                tw(f,{BackgroundColor3=D.s3h},0.1)
                setState(not on)
            end)

            local obj={}
            function obj:Set(v) setState(v) end
            function obj:Get() return on end
            return obj
        end

        -- ── BUTTON ────────────────────────────────────────────────────────
        function Tab:Button(cfg)
            cfg=cfg or {}
            local title=cfg.Title    or "Button"
            local desc =cfg.Desc     or ""
            local cb   =cfg.Callback or function()end

            local h=desc~="" and 46 or 32
            local f=mkRow(h)

            new("TextLabel",{
                Text=title, TextSize=12, Font=Enum.Font.GothamSemibold,
                TextColor3=D.t1, BackgroundTransparency=1,
                Size=UDim2.new(1,-32,0,16),
                Position=UDim2.new(0,10,0,desc~="" and 6 or 8),
                TextXAlignment=Enum.TextXAlignment.Left, Parent=f,
            })
            if desc~="" then
                new("TextLabel",{
                    Text=desc, TextSize=10, Font=Enum.Font.Gotham,
                    TextColor3=D.t3, BackgroundTransparency=1,
                    Size=UDim2.new(1,-32,0,13),
                    Position=UDim2.new(0,10,0,24),
                    TextXAlignment=Enum.TextXAlignment.Left,
                    TextWrapped=true, Parent=f,
                })
            end
            -- Right arrow in accent
            new("TextLabel",{
                Text="›", TextSize=15, Font=Enum.Font.GothamBold,
                TextColor3=D.accS, BackgroundTransparency=1,
                Size=UDim2.fromOffset(18,h),
                Position=UDim2.new(1,-22,0,0),
                TextXAlignment=Enum.TextXAlignment.Center, Parent=f,
            })

            local cl=new("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false,Parent=f})
            cl.MouseEnter:Connect(function()    tw(f,{BackgroundColor3=D.s3h},0.1) end)
            cl.MouseLeave:Connect(function()    tw(f,{BackgroundColor3=D.s3},0.1) end)
            cl.MouseButton1Down:Connect(function() tw(f,{BackgroundColor3=D.s3p},0.07) end)
            cl.MouseButton1Up:Connect(function()
                tw(f,{BackgroundColor3=D.s3h},0.1)
                task.spawn(cb)
            end)
        end

        -- ── SLIDER ────────────────────────────────────────────────────────
        function Tab:Slider(cfg)
            cfg=cfg or {}
            local title=cfg.Title    or "Slider"
            local desc =cfg.Desc     or ""
            local sMin =cfg.Min      or 0
            local sMax =cfg.Max      or 100
            local sDef =cfg.Default  or sMin
            local sRnd =cfg.Rounding or 0
            local cb   =cfg.Callback or function()end

            local val=sDef local isDrag=false
            local h=desc~="" and 56 or 44
            local f=mkRow(h)

            -- Title + live value
            new("TextLabel",{
                Text=title, TextSize=12, Font=Enum.Font.GothamSemibold,
                TextColor3=D.t1, BackgroundTransparency=1,
                Size=UDim2.new(0.62,0,0,16),
                Position=UDim2.new(0,10,0,desc~="" and 5 or 6),
                TextXAlignment=Enum.TextXAlignment.Left, Parent=f,
            })
            local valLbl=new("TextLabel",{
                Text=tostring(sDef), TextSize=11, Font=Enum.Font.GothamBold,
                TextColor3=D.acc, BackgroundTransparency=1,
                Size=UDim2.new(0.32,0,0,16),
                Position=UDim2.new(0.66,0,0,desc~="" and 5 or 6),
                TextXAlignment=Enum.TextXAlignment.Right, Parent=f,
            })
            if desc~="" then
                new("TextLabel",{
                    Text=desc, TextSize=10, Font=Enum.Font.Gotham,
                    TextColor3=D.t3, BackgroundTransparency=1,
                    Size=UDim2.new(1,-20,0,12),
                    Position=UDim2.new(0,10,0,22),
                    TextXAlignment=Enum.TextXAlignment.Left,
                    TextWrapped=true, Parent=f,
                })
            end

            -- Track
            local ty=desc~="" and 38 or 28
            local tbg=new("Frame",{
                Size=UDim2.new(1,-20,0,4),
                Position=UDim2.new(0,10,0,ty),
                BackgroundColor3=D.togOff,
                BorderSizePixel=0, ClipsDescendants=false, Parent=f,
            },{rnd(2)})
            local fill=new("Frame",{
                Size=UDim2.new(0,0,1,0),
                BackgroundColor3=D.acc,
                BorderSizePixel=0, Parent=tbg,
            },{rnd(2)})
            local dot=new("Frame",{
                Size=UDim2.fromOffset(11,11),
                AnchorPoint=Vector2.new(0.5,0.5),
                Position=UDim2.new(0,0,0.5,0),
                BackgroundColor3=Color3.fromRGB(255,255,255),
                BorderSizePixel=0, ZIndex=5, Parent=fill,
            },{rnd(6), uist(D.accS,1.5,0)})

            local function rn(n,fac)
                if fac==0 then return math.floor(n+0.5) end
                return math.floor(n/fac+0.5)*fac
            end
            local function setVal(v)
                val=math.clamp(rn(v,sRnd),sMin,sMax)
                local pct=(val-sMin)/math.max(sMax-sMin,0.001)
                tw(fill,{Size=UDim2.new(pct,0,1,0)},0.06,Enum.EasingStyle.Linear)
                valLbl.Text=tostring(val)
                task.spawn(cb,val)
            end
            setVal(sDef)

            tbg.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then
                    isDrag=true
                    setVal(sMin+(sMax-sMin)*math.clamp((i.Position.X-tbg.AbsolutePosition.X)/tbg.AbsoluteSize.X,0,1))
                end
            end)
            UIS.InputChanged:Connect(function(i)
                if isDrag and i.UserInputType==Enum.UserInputType.MouseMovement then
                    setVal(sMin+(sMax-sMin)*math.clamp((i.Position.X-tbg.AbsolutePosition.X)/tbg.AbsoluteSize.X,0,1))
                end
            end)
            UIS.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then isDrag=false end
            end)

            local obj={}
            function obj:Set(v) setVal(v) end
            function obj:Get() return val end
            return obj
        end

        -- ── INPUT ─────────────────────────────────────────────────────────
        function Tab:Input(cfg)
            cfg=cfg or {}
            local title=cfg.Title       or "Input"
            local desc =cfg.Desc        or ""
            local ph   =cfg.Placeholder or "Type here..."
            local def  =cfg.Default     or ""
            local clrf =cfg.ClearOnFocus; if clrf==nil then clrf=false end
            local cb   =cfg.Callback    or function()end

            local h=desc~="" and 58 or 46
            local f=mkRow(h)

            new("TextLabel",{
                Text=title, TextSize=12, Font=Enum.Font.GothamSemibold,
                TextColor3=D.t1, BackgroundTransparency=1,
                Size=UDim2.new(1,-20,0,16),
                Position=UDim2.new(0,10,0,desc~="" and 4 or 6),
                TextXAlignment=Enum.TextXAlignment.Left, Parent=f,
            })
            if desc~="" then
                new("TextLabel",{
                    Text=desc, TextSize=10, Font=Enum.Font.Gotham,
                    TextColor3=D.t3, BackgroundTransparency=1,
                    Size=UDim2.new(1,-20,0,12),
                    Position=UDim2.new(0,10,0,21),
                    TextXAlignment=Enum.TextXAlignment.Left, Parent=f,
                })
            end

            local iy=desc~="" and 35 or 24
            local ibg=new("Frame",{
                Size=UDim2.new(1,-20,0,20),
                Position=UDim2.new(0,10,0,iy),
                BackgroundColor3=D.s0,
                BorderSizePixel=0, Parent=f,
            },{rnd(4), uist(D.b1,1,0)})
            local ibgs=ibg:FindFirstChildOfClass("UIStroke")

            local ib=new("TextBox",{
                Size=UDim2.new(1,-8,1,0), Position=UDim2.new(0,5,0,0),
                BackgroundTransparency=1, Text=def,
                PlaceholderText=ph, PlaceholderColor3=D.t3,
                TextSize=11, Font=Enum.Font.Gotham,
                TextColor3=D.t1, TextXAlignment=Enum.TextXAlignment.Left,
                ClearTextOnFocus=clrf, Parent=ibg,
            })
            ib.Focused:Connect(function()
                tw(ibg,{BackgroundColor3=D.s3h},0.12)
                if ibgs then tw(ibgs,{Color=D.acc},0.12) end
            end)
            ib.FocusLost:Connect(function()
                tw(ibg,{BackgroundColor3=D.s0},0.12)
                if ibgs then tw(ibgs,{Color=D.b1},0.12) end
                task.spawn(cb,ib.Text)
            end)
        end

        -- ── DROPDOWN ──────────────────────────────────────────────────────
        function Tab:Dropdown(cfg)
            cfg=cfg or {}
            local title=cfg.Title    or "Dropdown"
            local desc =cfg.Desc     or ""
            local list =cfg.List     or {}
            local def  =cfg.Value    or ""
            local cb   =cfg.Callback or function()end

            local sel=def local open=false
            local BH=desc~="" and 46 or 32 local IH=24

            local outer=new("Frame",{
                Size=UDim2.new(1,0,0,BH),
                BackgroundColor3=D.s3,
                BorderSizePixel=0, ClipsDescendants=false, Parent=page,
            },{rnd(6), uist(D.b1,1,0.5)})

            -- Header
            local hdr=new("Frame",{
                Size=UDim2.new(1,0,0,BH),
                BackgroundTransparency=1, ClipsDescendants=true, Parent=outer,
            })
            new("TextLabel",{
                Text=title, TextSize=12, Font=Enum.Font.GothamSemibold,
                TextColor3=D.t1, BackgroundTransparency=1,
                Size=UDim2.new(0.5,0,0,16),
                Position=UDim2.new(0,10,0,desc~="" and 5 or 8),
                TextXAlignment=Enum.TextXAlignment.Left, Parent=hdr,
            })
            if desc~="" then
                new("TextLabel",{
                    Text=desc, TextSize=10, Font=Enum.Font.Gotham,
                    TextColor3=D.t3, BackgroundTransparency=1,
                    Size=UDim2.new(0.6,0,0,12),
                    Position=UDim2.new(0,10,0,22),
                    TextXAlignment=Enum.TextXAlignment.Left,
                    TextWrapped=true, Parent=hdr,
                })
            end
            local selLbl=new("TextLabel",{
                Text=sel~="" and sel or "Select...",
                TextSize=11, Font=Enum.Font.Gotham,
                TextColor3=D.t2, BackgroundTransparency=1,
                Size=UDim2.new(0.35,0,0,BH),
                Position=UDim2.new(0.55,0,0,0),
                TextXAlignment=Enum.TextXAlignment.Right, Parent=hdr,
            })
            local arrow=new("TextLabel",{
                Text="›", TextSize=13, Font=Enum.Font.GothamBold,
                TextColor3=D.t3, BackgroundTransparency=1,
                Size=UDim2.new(0,18,0,BH),
                Position=UDim2.new(1,-22,0,0),
                TextXAlignment=Enum.TextXAlignment.Center,
                Rotation=90, Parent=hdr,
            })

            -- List panel
            local lp=new("Frame",{
                Size=UDim2.new(1,0,0,0),
                Position=UDim2.new(0,0,0,BH+1),
                BackgroundColor3=D.s3h,
                BorderSizePixel=0, ClipsDescendants=true, ZIndex=10, Parent=outer,
            },{rnd(6), uist(D.b1,1,0.5), upd(2,2,4,4), ull(2)})

            local function calcH() return math.min(#list*IH+4,140) end
            local function buildList()
                for _,v in ipairs(lp:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
                for _,opt in ipairs(list) do
                    local isSel=opt==sel
                    local b=new("TextButton",{
                        Text=opt, TextSize=11,
                        Font=isSel and Enum.Font.GothamBold or Enum.Font.Gotham,
                        TextColor3=isSel and D.accH or D.t2,
                        BackgroundColor3=isSel and D.accB or D.s3,
                        Size=UDim2.new(1,0,0,IH-2),
                        AutoButtonColor=false, TextXAlignment=Enum.TextXAlignment.Left,
                        ZIndex=11, Parent=lp,
                    },{rnd(4),upd(0,0,6,0)})
                    b.MouseEnter:Connect(function()
                        if opt~=sel then tw(b,{BackgroundColor3=D.s3p},0.08) end
                    end)
                    b.MouseLeave:Connect(function()
                        if opt~=sel then tw(b,{BackgroundColor3=D.s3},0.08) end
                    end)
                    b.MouseButton1Click:Connect(function()
                        sel=opt selLbl.Text=opt buildList()
                        task.spawn(cb,opt)
                    end)
                end
            end
            buildList()

            local function setOpen(s)
                open=s local th=s and calcH() or 0
                tw(lp,   {Size=UDim2.new(1,0,0,th)},0.16)
                tw(outer,{Size=UDim2.new(1,0,0,BH+(s and th+2 or 0))},0.16)
                tw(arrow,{Rotation=s and 270 or 90},0.16)
            end

            local hc=new("TextButton",{
                Size=UDim2.new(1,0,0,BH),
                BackgroundTransparency=1, Text="", AutoButtonColor=false, Parent=hdr,
            })
            hc.MouseButton1Click:Connect(function() setOpen(not open) end)
            hc.MouseEnter:Connect(function() tw(outer,{BackgroundColor3=D.s3h},0.1) end)
            hc.MouseLeave:Connect(function() tw(outer,{BackgroundColor3=D.s3},0.1) end)

            local obj={Value=sel}
            function obj:UpdateList(l) list=l buildList() if open then local h=calcH() tw(lp,{Size=UDim2.new(1,0,0,h)},0.14) tw(outer,{Size=UDim2.new(1,0,0,BH+h+2)},0.14) end end
            function obj:SetValue(v) sel=v selLbl.Text=v~="" and v or "Select..." obj.Value=v buildList() end
            function obj:GetValue() return sel end
            return obj
        end

        -- ── LABEL ─────────────────────────────────────────────────────────
        function Tab:Label(cfg)
            cfg=cfg or {}
            local title=cfg.Title or "Info"
            local desc =cfg.Desc  or "—"

            local f=mkRow(nil,true) -- auto height
            f.Size=UDim2.new(1,0,0,0)

            new("TextLabel",{
                Text=title, TextSize=11, Font=Enum.Font.GothamSemibold,
                TextColor3=D.t2, BackgroundTransparency=1,
                Size=UDim2.new(0.4,0,0,32),
                Position=UDim2.new(0,10,0,0),
                TextXAlignment=Enum.TextXAlignment.Left,
                TextYAlignment=Enum.TextYAlignment.Center, Parent=f,
            })
            local valLbl=new("TextLabel",{
                Text=desc, TextSize=11, Font=Enum.Font.Gotham,
                TextColor3=D.t1, BackgroundTransparency=1,
                Size=UDim2.new(0.55,0,0,32),
                Position=UDim2.new(0.42,0,0,0),
                TextXAlignment=Enum.TextXAlignment.Right,
                TextYAlignment=Enum.TextYAlignment.Center,
                TextWrapped=true, Parent=f,
            })

            local obj={}
            function obj:Set(v)
                valLbl.Text=tostring(v)
            end
            return obj
        end

        return Tab
    end

    function Win:Notify(cfg) Notify(cfg) end
    return Win
end

return DaggerLib
