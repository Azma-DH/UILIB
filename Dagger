                    Parent             = Frame,
                })
            end

            -- Toggle pill track
            local Track = New("Frame", {
                Size             = UDim2.fromOffset(36, 20),
                Position         = UDim2.new(1, -46, 0.5, -10),
                BackgroundColor3 = T.ToggleOff,
                BorderSizePixel  = 0,
                Parent           = Frame,
            }, {
                Corner(10),
                Stroke(T.Stroke, 1, 0.4),
            })

            -- Toggle pill thumb
            local Thumb = New("Frame", {
                Size             = UDim2.fromOffset(14, 14),
                Position         = UDim2.fromOffset(3, 3),
                BackgroundColor3 = T.TextSecondary,
                BorderSizePixel  = 0,
                Parent           = Track,
            }, { Corner(7) })

            local function SetToggle(state, silent)
                toggled = state
                if state then
                    Tween(Track, { BackgroundColor3 = T.ToggleOn }, 0.22)
                    Tween(Thumb, { Position = UDim2.fromOffset(19, 3), BackgroundColor3 = Color3.fromRGB(255,255,255) }, 0.22)
                else
                    Tween(Track, { BackgroundColor3 = T.ToggleOff }, 0.22)
                    Tween(Thumb, { Position = UDim2.fromOffset(3, 3), BackgroundColor3 = T.TextSecondary }, 0.22)
                end
                if not silent then
                    task.spawn(tCallback, state)
                end
            end

            SetToggle(tDefault, true)

            local Click = New("TextButton", {
                Size               = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text               = "",
                AutoButtonColor    = false,
