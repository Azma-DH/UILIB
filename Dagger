-- ─── Tween shorthand ─────────────────────────────────────────────────────────
local function tw(obj, props, t, style, dir)
    TS:Create(obj, TweenInfo.new(
        t     or 0.2,
        style or Enum.EasingStyle.Quint,
        dir   or Enum.EasingDirection.Out
    ), props):Play()
end

-- ─── Instance factory ────────────────────────────────────────────────────────
local function new(class, props, children)
    local inst = Instance.new(class)
    for k,v in pairs(props    or {}) do inst[k] = v end
    for _,v in pairs(children or {}) do v.Parent = inst end
    return inst
end

local function rnd(r)   return new("UICorner",  { CornerRadius=UDim.new(0,r or 6) }) end
local function uist(c,t,tr) return new("UIStroke", { Color=c, Thickness=t or 1, Transparency=tr or 0 }) end
local function ull(p)   return new("UIListLayout", { Padding=UDim.new(0,p or 0), SortOrder=Enum.SortOrder.LayoutOrder }) end
local function upd(t,b,l,r)
    return new("UIPadding",{
        PaddingTop=UDim.new(0,t or 0),  PaddingBottom=UDim.new(0,b or 0),
        PaddingLeft=UDim.new(0,l or 0), PaddingRight=UDim.new(0,r or 0),
    })
end

