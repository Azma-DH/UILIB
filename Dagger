    local activeTabBtn = nil

    function WindowObj:Tab(tabConfig)
        tabConfig      = tabConfig or {}
        local tabName  = tabConfig.Title or "Tab"
        local tabIcon  = tabConfig.Icon  or ""

        -- Sidebar tab button
        local TabBtn = New("TextButton", {
            Size             = UDim2.new(1, -8, 0, 30),
            BackgroundColor3 = T.Sidebar,
            AutoButtonColor  = false,
            Text             = "",
            BorderSizePixel  = 0,
            Parent           = Sidebar,
        }, { Corner(7) })

        -- Accent bar on left edge of active tab
        local ActiveBar = New("Frame", {
            Size             = UDim2.new(0, 3, 0.6, 0),
            Position         = UDim2.new(0, 0, 0.2, 0),
            BackgroundColor3 = T.Accent,
            BorderSizePixel  = 0,
            Visible          = false,
            Parent           = TabBtn,
        }, { Corner(2) })

        -- Tab label
        local TabLabel = New("TextLabel", {
            Text               = tabName,
            TextSize           = 12,
            Font               = Enum.Font.GothamSemibold,
            TextColor3         = T.TextDim,
            BackgroundTransparency = 1,
            Size               = UDim2.new(1, -10, 1, 0),
            Position           = UDim2.new(0, 10, 0, 0),
            TextXAlignment     = Enum.TextXAlignment.Left,
            Parent             = TabBtn,
        })

        -- Each tab gets its own content frame (hidden by default)
        local TabContent = New("Frame", {
            Size               = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Visible            = false,
            Parent             = ContentArea,
        }, {
            ListLayout(6),
            New("UISizeConstraint", { MaxSize = Vector2.new(math.huge, math.huge) }),
        })

        local function Activate()
            -- Deactivate all
            for _, t in ipairs(tabs) do
                t.content.Visible = false
                Tween(t.btn, { BackgroundColor3 = T.Sidebar }, 0.2)
                Tween(t.label, { TextColor3 = T.TextDim }, 0.2)
                t.bar.Visible = false
            end
            -- Activate this
            TabContent.Visible = true
            Tween(TabBtn, { BackgroundColor3 = T.Element }, 0.2)
            Tween(TabLabel, { TextColor3 = T.TextPrimary }, 0.2)
            ActiveBar.Visible = true
            activeTabBtn = TabBtn
        end

        TabBtn.MouseButton1Click:Connect(Activate)

        TabBtn.MouseEnter:Connect(function()
            if TabBtn ~= activeTabBtn then
                TweenQuad(TabBtn, { BackgroundColor3 = Color3.fromRGB(20, 16, 28) })
            end
        end)
        TabBtn.MouseLeave:Connect(function()
            if TabBtn ~= activeTabBtn then
                TweenQuad(TabBtn, { BackgroundColor3 = T.Sidebar })
            end
        end)

        table.insert(tabs, { btn = TabBtn, label = TabLabel, bar = ActiveBar, content = TabContent })

        if firstTab then
            firstTab = false
            Activate()
        end

