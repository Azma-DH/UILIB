--[[
  DaggerLib — Orca-clone UI for Roblox executors
  GitHub: https://raw.githubusercontent.com/Azma-DH/UILIB/refs/heads/main/Dagger

  API:
    local Lib = loadstring(game:HttpGet(RAW_URL))()
    local Win = Lib:Window({ Title="Dagger", Version="v1.0", Key=Enum.KeyCode.LeftControl })
    local Tab = Win:Tab({ Title="Defense", Icon="🛡" })

    Tab:Toggle({ Title="Anti Kick",    Tag="Protection", Desc="Stops local kick scripts.",  Default=false,  Callback=function(v) end })
    Tab:Button({ Title="Teleport",     Tag="Utility",    Desc="Go to the safe zone.",        Callback=function() end })
    Tab:Slider({ Title="Walk Speed",   Tag="Movement",   Desc="Change movement speed.",      Min=16, Max=300, Default=16, Rounding=0, Callback=function(v) end })
    Tab:Input({  Title="Set Goal",     Tag="Tracking",   Desc="e.g. 500M",                  Placeholder="500M", Callback=function(v) end })
    Tab:Dropdown({Title="Target",      Tag="Combat",     Desc="Pick a target player.",       List={"A","B"},  Callback=function(v) end })
    local lbl = Tab:Label({ Title="Strength", Tag="Info", Desc="0" })
    lbl:Set("1.5B")
    Tab:Divider()
    Win:Notify({ Title="Done", Desc="Finished.", Duration=4 })
]]

-- ─── Services ────────────────────────────────────────────────────────────────
local TweenService     = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players          = game:GetService("Players")
local LocalPlayer      = Players.LocalPlayer

-- ─── Tween helper ────────────────────────────────────────────────────────────
local function Tween(obj, props, t, style, dir)
    TweenService:Create(obj,
        TweenInfo.new(t or 0.18, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out),
        props
    ):Play()
end

-- ─── Instance factory ────────────────────────────────────────────────────────
local function New(class, props, children)
    local inst = Instance.new(class)
    for k, v in pairs(props    or {}) do inst[k] = v end
    for _, v in pairs(children or {}) do v.Parent = inst end
    return inst
end

local function Corner(r)  return New("UICorner",  { CornerRadius = UDim.new(0, r or 6) }) end
local function Stroke(c, th, tr) return New("UIStroke", { Color=c, Thickness=th or 1, Transparency=tr or 0 }) end
local function List(p)    return New("UIListLayout", { Padding=UDim.new(0, p or 0), SortOrder=Enum.SortOrder.LayoutOrder }) end
local function Pad(t,b,l,r)
    return New("UIPadding", {
        PaddingTop=UDim.new(0,t or 0), PaddingBottom=UDim.new(0,b or 0),
        PaddingLeft=UDim.new(0,l or 0), PaddingRight=UDim.new(0,r or 0),
    })
end

