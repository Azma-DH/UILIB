				Text=bName, TextSize=13, Font=Enum.Font.GothamSemibold, TextColor3=C.TxtHi,
				BackgroundTransparency=1, Size=UDim2.new(1,-44,0,16),
				Position=UDim2.new(0,12,0,bDesc~="" and 7 or 9),
				TextXAlignment=Enum.TextXAlignment.Left, Parent=f,
			})
			if bDesc~="" then
				new("TextLabel",{
					Text=bDesc, TextSize=11, Font=Enum.Font.Gotham, TextColor3=C.TxtMid,
					BackgroundTransparency=1, Size=UDim2.new(1,-44,0,14),
					Position=UDim2.new(0,12,0,26), TextXAlignment=Enum.TextXAlignment.Left,
					TextWrapped=true, Parent=f,
				})
			end
			new("TextLabel",{
				Text="›", TextSize=20, Font=Enum.Font.GothamBold, TextColor3=C.AccentLo,
				BackgroundTransparency=1, Size=UDim2.new(0,24,1,0),
				Position=UDim2.new(1,-30,0,0), TextXAlignment=Enum.TextXAlignment.Center, Parent=f,
			})
			local click = new("TextButton",{
				Size=UDim2.new(1,0,1,0), BackgroundTransparency=1,
				Text="", AutoButtonColor=false, Parent=f,
			})
			click.MouseEnter:Connect(function()       tween(f,{BackgroundColor3=C.ElemHov},0.12) end)
			click.MouseLeave:Connect(function()       tween(f,{BackgroundColor3=C.Elem},0.12) end)
			click.MouseButton1Down:Connect(function() tween(f,{BackgroundColor3=C.ElemPrs},0.08) end)
			click.MouseButton1Up:Connect(function()   tween(f,{BackgroundColor3=C.ElemHov},0.12) task.spawn(bCb) end)
		end

		function Tab:Toggle(cfg)
			cfg = cfg or {}
			local tName = cfg.Title    or "Toggle"
			local tDesc = cfg.Desc     or ""
			local tDef  = cfg.Value
			if tDef==nil then tDef=false end
			local tCb   = cfg.Callback or function() end
			local toggled = tDef
			local h = tDesc~="" and 48 or 34
			local f = base(h)
			new("TextLabel",{
				Text=tName, TextSize=13, Font=Enum.Font.GothamSemibold, TextColor3=C.TxtHi,
				BackgroundTransparency=1, Size=UDim2.new(1,-62,0,16),
				Position=UDim2.new(0,12,0,tDesc~="" and 7 or 9),
				TextXAlignment=Enum.TextXAlignment.Left, Parent=f,
			})
			if tDesc~="" then
				new("TextLabel",{
					Text=tDesc, TextSize=11, Font=Enum.Font.Gotham, TextColor3=C.TxtMid,
					BackgroundTransparency=1, Size=UDim2.new(1,-62,0,14),
					Position=UDim2.new(0,12,0,26), TextXAlignment=Enum.TextXAlignment.Left,
					TextWrapped=true, Parent=f,
				})
			end
			local track = new("Frame",{
				Size=UDim2.fromOffset(38,20), Position=UDim2.new(1,-50,0.5,-10),
				BackgroundColor3=C.TogOff, BorderSizePixel=0, Parent=f,
			},{corner(10),stroke(C.Stroke,1,0.3)})
			local thumb = new("Frame",{
				Size=UDim2.fromOffset(14,14), Position=UDim2.fromOffset(3,3),
				BackgroundColor3=C.TxtLo, BorderSizePixel=0, Parent=track,
			},{corner(7)})
			local function setState(val, silent)
				toggled=val
				if val then
					tween(track,{BackgroundColor3=C.TogOn},0.2)
					tween(thumb,{Position=UDim2.fromOffset(21,3),BackgroundColor3=Color3.fromRGB(255,255,255)},0.2)
				else
					tween(track,{BackgroundColor3=C.TogOff},0.2)
					tween(thumb,{Position=UDim2.fromOffset(3,3),BackgroundColor3=C.TxtLo},0.2)
				end
				if not silent then task.spawn(tCb,val) end
			end
			setState(tDef,true)
			local click = new("TextButton",{
				Size=UDim2.new(1,0,1,0), BackgroundTransparency=1,
				Text="", AutoButtonColor=false, Parent=f,
			})
			click.MouseEnter:Connect(function()  tween(f,{BackgroundColor3=C.ElemHov},0.12) end)
			click.MouseLeave:Connect(function()  tween(f,{BackgroundColor3=C.Elem},0.12) end)
			click.MouseButton1Up:Connect(function() setState(not toggled) end)
			local obj={}
			function obj:Set(v) setState(v) end
			function obj:Get()  return toggled end
			return obj
		end

		function Tab:Slider(cfg)
			cfg = cfg or {}
			local sName = cfg.Title    or "Slider"
			local sDesc = cfg.Desc     or ""
			local sMin  = cfg.Min      or 0
			local sMax  = cfg.Max      or 100
			local sDef  = cfg.Value    or sMin
			local sRnd  = cfg.Rounding or 0
			local sCb   = cfg.Callback or function() end
			local val   = sDef
			local isDrag= false
			local h = sDesc~="" and 62 or 50
			local f = base(h)
			local trow = new("Frame",{
				Size=UDim2.new(1,-24,0,16), Position=UDim2.new(0,12,0,8),
				BackgroundTransparency=1, Parent=f,
			})
			new("TextLabel",{
				Text=sName, TextSize=13, Font=Enum.Font.GothamSemibold, TextColor3=C.TxtHi,
				BackgroundTransparency=1, Size=UDim2.new(0.65,0,1,0),
				TextXAlignment=Enum.TextXAlignment.Left, Parent=trow,
			})
			local valLbl = new("TextLabel",{
				Text=tostring(sDef), TextSize=12, Font=Enum.Font.GothamBold, TextColor3=C.Accent,
				BackgroundTransparency=1, Size=UDim2.new(0.35,0,1,0),
				Position=UDim2.new(0.65,0,0,0), TextXAlignment=Enum.TextXAlignment.Right, Parent=trow,
			})
			if sDesc~="" then
				new("TextLabel",{
					Text=sDesc, TextSize=11, Font=Enum.Font.Gotham, TextColor3=C.TxtMid,
					BackgroundTransparency=1, Size=UDim2.new(1,-24,0,13),
					Position=UDim2.new(0,12,0,26), TextXAlignment=Enum.TextXAlignment.Left,
					TextWrapped=true, Parent=f,
				})
			end
			local trackY = sDesc~="" and 46 or 34
			local trackBg = new("Frame",{
				Size=UDim2.new(1,-24,0,6), Position=UDim2.new(0,12,0,trackY),
				BackgroundColor3=C.Div, BorderSizePixel=0, ClipsDescendants=false, Parent=f,
			},{corner(3)})
			local fill = new("Frame",{
				Size=UDim2.new(0,0,1,0), BackgroundColor3=C.Accent,
				BorderSizePixel=0, Parent=trackBg,
			},{corner(3)})
			local thumbDot = new("Frame",{
				Size=UDim2.fromOffset(13,13), AnchorPoint=Vector2.new(0.5,0.5),
				Position=UDim2.new(0,0,0.5,0), BackgroundColor3=Color3.fromRGB(255,255,255),
				BorderSizePixel=0, ZIndex=5, Parent=fill,
			},{corner(7),stroke(C.Accent,2,0)})
			local function rnd(n,factor)
				if factor==0 then return math.floor(n+0.5) end
				return math.floor(n/factor+0.5)*factor
			end
			local function setVal(v)
				val = math.clamp(rnd(v,sRnd),sMin,sMax)
				local pct = (val-sMin)/math.max(sMax-sMin,0.0001)
				tween(fill,{Size=UDim2.new(pct,0,1,0)},0.08,Enum.EasingStyle.Linear)
				valLbl.Text = tostring(val)
				task.spawn(sCb,val)
			end
			setVal(sDef)
			trackBg.InputBegan:Connect(function(i)
				if i.UserInputType==Enum.UserInputType.MouseButton1 then
					isDrag=true
					local pct=math.clamp((i.Position.X-trackBg.AbsolutePosition.X)/trackBg.AbsoluteSize.X,0,1)
					setVal(sMin+(sMax-sMin)*pct)
				end
			end)
			UIS.InputChanged:Connect(function(i)
				if isDrag and i.UserInputType==Enum.UserInputType.MouseMovement then
					local pct=math.clamp((i.Position.X-trackBg.AbsolutePosition.X)/trackBg.AbsoluteSize.X,0,1)
					setVal(sMin+(sMax-sMin)*pct)
				end
			end)
			UIS.InputEnded:Connect(function(i)
				if i.UserInputType==Enum.UserInputType.MouseButton1 then isDrag=false end
			end)
			local obj={}
			function obj:Set(v) setVal(v) end
			function obj:Get()  return val end
			return obj
		end

		function Tab:Textbox(cfg)
			cfg = cfg or {}
			local txName  = cfg.Title            or "Input"
			local txDesc  = cfg.Desc             or ""
			local txPh    = cfg.Placeholder      or "Type here..."
			local txDef   = cfg.Value            or ""
			local txClear = cfg.ClearTextOnFocus
			if txClear==nil then txClear=false end
			local txCb    = cfg.Callback         or function() end
			local h = txDesc~="" and 62 or 50
			local f = base(h)
			new("TextLabel",{
				Text=txName, TextSize=13, Font=Enum.Font.GothamSemibold, TextColor3=C.TxtHi,
				BackgroundTransparency=1, Size=UDim2.new(1,-24,0,16),
				Position=UDim2.new(0,12,0,7), TextXAlignment=Enum.TextXAlignment.Left, Parent=f,
			})
			if txDesc~="" then
				new("TextLabel",{
					Text=txDesc, TextSize=11, Font=Enum.Font.Gotham, TextColor3=C.TxtMid,
					BackgroundTransparency=1, Size=UDim2.new(1,-24,0,13),
					Position=UDim2.new(0,12,0,24), TextXAlignment=Enum.TextXAlignment.Left,
					TextWrapped=true, Parent=f,
				})
			end
			local inputY = txDesc~="" and 40 or 28
			local ibg = new("Frame",{
				Size=UDim2.new(1,-24,0,24), Position=UDim2.new(0,12,0,inputY),
				BackgroundColor3=C.Win, BorderSizePixel=0, Parent=f,
			},{corner(5),stroke(C.Stroke,1,0.3)})
			local ibox = new("TextBox",{
				Size=UDim2.new(1,-12,1,0), Position=UDim2.new(0,8,0,0),
				BackgroundTransparency=1, Text=txDef, PlaceholderText=txPh,
				PlaceholderColor3=C.TxtLo, TextSize=12, Font=Enum.Font.Gotham,
				TextColor3=C.TxtHi, TextXAlignment=Enum.TextXAlignment.Left,
				ClearTextOnFocus=txClear, Parent=ibg,
			})
			local ibgS = ibg:FindFirstChildOfClass("UIStroke")
			ibox.Focused:Connect(function()
				tween(ibg,{BackgroundColor3=C.ElemHov},0.15)
				if ibgS then tween(ibgS,{Color=C.Accent},0.15) end
			end)
			ibox.FocusLost:Connect(function()
				tween(ibg,{BackgroundColor3=C.Win},0.15)
				if ibgS then tween(ibgS,{Color=C.Stroke},0.15) end
				task.spawn(txCb,ibox.Text)
			end)
		end

		function Tab:Dropdown(cfg)
			cfg = cfg or {}
			local ddName = cfg.Title    or "Dropdown"
			local ddList = cfg.List     or {}
			local ddDef  = cfg.Value    or ""
			local ddCb   = cfg.Callback or function() end
			local selected = ddDef
			local open     = false
			local BASE_H   = 36
			local ITEM_H   = 26

			local outer = new("Frame",{
				Size=UDim2.new(1,0,0,BASE_H), BackgroundColor3=C.Elem,
				BorderSizePixel=0, ClipsDescendants=false, Parent=Page,
			},{corner(7),stroke(C.Stroke,1,0.6)})

			local header = new("Frame",{
				Size=UDim2.new(1,0,0,BASE_H), BackgroundTransparency=1,
				ClipsDescendants=true, Parent=outer,
			})
			new("TextLabel",{
				Text=ddName, TextSize=13, Font=Enum.Font.GothamSemibold, TextColor3=C.TxtHi,
				BackgroundTransparency=1, Size=UDim2.new(0.5,0,1,0),
				Position=UDim2.new(0,12,0,0), TextXAlignment=Enum.TextXAlignment.Left, Parent=header,
			})
			local selLbl = new("TextLabel",{
				Text=selected~="" and selected or "Select...",
				TextSize=12, Font=Enum.Font.Gotham, TextColor3=C.TxtMid,
				BackgroundTransparency=1, Size=UDim2.new(0.38,0,1,0),
				Position=UDim2.new(0.5,0,0,0), TextXAlignment=Enum.TextXAlignment.Right, Parent=header,
			})
			local arrow = new("TextLabel",{
				Text="›", TextSize=16, Font=Enum.Font.GothamBold, TextColor3=C.TxtLo,
				BackgroundTransparency=1, Size=UDim2.new(0,24,1,0),
				Position=UDim2.new(1,-28,0,0), TextXAlignment=Enum.TextXAlignment.Center,
				Rotation=90, Parent=header,
			})

			local listPanel = new("Frame",{
				Size=UDim2.new(1,0,0,0), Position=UDim2.new(0,0,0,BASE_H+2),
				BackgroundColor3=C.ElemHov, BorderSizePixel=0,
				ClipsDescendants=true, ZIndex=10, Parent=outer,
			},{corner(7),stroke(C.Stroke,1,0.5),pad(4,4,4,4),list(3)})

			local function calcH() return math.min(#ddList*ITEM_H+8,160) end

			local function buildList()
				for _,v in ipairs(listPanel:GetChildren()) do
					if v:IsA("TextButton") then v:Destroy() end
				end
				for _,opt in ipairs(ddList) do
					local isSel = opt==selected
					local btn = new("TextButton",{
						Text=opt, TextSize=12,
						Font=isSel and Enum.Font.GothamBold or Enum.Font.Gotham,
						TextColor3=isSel and C.AccentHi or C.TxtMid,
						BackgroundColor3=isSel and C.AccentLo or C.Elem,
						Size=UDim2.new(1,0,0,ITEM_H-3), AutoButtonColor=false,
						TextXAlignment=Enum.TextXAlignment.Left, ZIndex=11, Parent=listPanel,
					},{corner(5),pad(0,0,8,0)})
					btn.MouseEnter:Connect(function()
						if opt~=selected then tween(btn,{BackgroundColor3=C.ElemPrs},0.1) end
					end)
					btn.MouseLeave:Connect(function()
						if opt~=selected then tween(btn,{BackgroundColor3=C.Elem},0.1) end
					end)
					btn.MouseButton1Click:Connect(function()
						selected=opt selLbl.Text=opt buildList() task.spawn(ddCb,opt)
					end)
				end
			end
			buildList()

			local function setOpen(state)
				open=state
				local th = open and calcH() or 0
				tween(listPanel,{Size=UDim2.new(1,0,0,th)},0.2)
				tween(outer,{Size=UDim2.new(1,0,0,BASE_H+(open and th+4 or 0))},0.2)
				tween(arrow,{Rotation=open and 270 or 90},0.2)
			end

			local hClick = new("TextButton",{
				Size=UDim2.new(1,0,0,BASE_H), BackgroundTransparency=1,
				Text="", AutoButtonColor=false, Parent=header,
			})
			hClick.MouseButton1Click:Connect(function() setOpen(not open) end)
			hClick.MouseEnter:Connect(function() tween(outer,{BackgroundColor3=C.ElemHov},0.12) end)
			hClick.MouseLeave:Connect(function() tween(outer,{BackgroundColor3=C.Elem},0.12) end)

			local obj={}
			obj.Value=selected
			function obj:UpdateList(lst)
				ddList=lst buildList()
				if open then
					local h=calcH()
					tween(listPanel,{Size=UDim2.new(1,0,0,h)},0.15)
					tween(outer,{Size=UDim2.new(1,0,0,BASE_H+h+4)},0.15)
				end
			end
			function obj:SetValue(v)
				selected=v selLbl.Text=v~="" and v or "Select..." obj.Value=v buildList()
			end
			function obj:GetValue() return selected end
			return obj
		end

		function Tab:Code(cfg)
			cfg = cfg or {}
			local cTitle = cfg.Title or "Info"
			local cCode  = cfg.Code  or ""
			local f = new("Frame",{
				Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y,
				BackgroundColor3=C.Elem, BorderSizePixel=0,
				ClipsDescendants=false, Parent=Page,
			},{corner(7),stroke(C.Stroke,1,0.6),pad(6,8,12,12),list(2)})
			new("TextLabel",{
				Text=cTitle:upper(), TextSize=10, Font=Enum.Font.GothamBold,
				TextColor3=C.Accent, BackgroundTransparency=1,
				Size=UDim2.new(1,0,0,13), TextXAlignment=Enum.TextXAlignment.Left,
				LayoutOrder=0, Parent=f,
			})
			local content = new("TextLabel",{
				Text=cCode, TextSize=12, Font=Enum.Font.Code, TextColor3=C.TxtMid,
				BackgroundTransparency=1, Size=UDim2.new(1,0,0,0),
				AutomaticSize=Enum.AutomaticSize.Y, TextXAlignment=Enum.TextXAlignment.Left,
				TextWrapped=true, LayoutOrder=1, Parent=f,
			})
			local obj={}
			function obj:SetCode(v) content.Text=tostring(v) end
			return obj
		end

		function Tab:Label(cfg)
			cfg = cfg or {}
			local lbl = new("TextLabel",{
				Text=cfg.Text or "", TextSize=12, Font=Enum.Font.Gotham,
				TextColor3=C.TxtMid, BackgroundTransparency=1,
				Size=UDim2.new(1,0,0,18), TextXAlignment=Enum.TextXAlignment.Left,
				TextWrapped=true, Parent=Page,
			})
			local obj={}
			function obj:Set(v) lbl.Text=tostring(v) end
			return obj
		end

		function Tab:Line()
			new("Frame",{
				Size=UDim2.new(1,0,0,1), BackgroundColor3=C.Div,
				BorderSizePixel=0, Parent=Page,
			})
		end

		return Tab
	end

	function Win:Notify(cfg)
		cfg=cfg or {}
		Notify(cfg.Title,cfg.Desc,cfg.Time)
	end

	function Win:Line() end

	return Win
end

DaggerLib.Notify = Notify
return DaggerLib
