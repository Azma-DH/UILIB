                Tween(Frame, { BackgroundColor3 = T.ElementHover }, 0.15)
            end)
            Click.MouseLeave:Connect(function()
                Tween(Frame, { BackgroundColor3 = T.Element }, 0.15)
            end)
            Click.MouseButton1Up:Connect(function()
                SetToggle(not toggled)
            end)

            -- Return object with :Set() method
            local ToggleObj = {}
            function ToggleObj:Set(v) SetToggle(v) end
            function ToggleObj:Get() return toggled end
            return ToggleObj
        end

        -- тФАтФА Slider тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
        function Tab:Slider(sConfig)
            sConfig          = sConfig or {}
            local sName      = sConfig.Title    or "Slider"
            local sDesc      = sConfig.Desc     or ""
            local sMin       = sConfig.Min      or 0
            local sMax       = sConfig.Max      or 100
            local sDefault   = sConfig.Value    or sMin
            local sRound     = sConfig.Rounding or 0
            local sCallback  = sConfig.Callback or function() end

            local value      = sDefault
            local dragging   = false
            local Frame      = ElemBase(sDesc ~= "" and 60 or 50)

            local titleRow = New("Frame", {
                Size             = UDim2.new(1, -12, 0, 16),
                Position         = UDim2.new(0, 12, 0, 8),
                BackgroundTransparency = 1,
                Parent           = Frame,
            })

            New("TextLabel", {
                Text               = sName,
                TextSize           = 13,
                Font               = Enum.Font.GothamSemibold,
                TextColor3         = T.TextPrimary,
                BackgroundTransparency = 1,
                Size               = UDim2.new(0.7, 0, 1, 0),
                TextXAlignment     = Enum.TextXAlignment.Left,
                Parent             = titleRow,
            })

            local ValLabel = New("TextLabel", {
                Text               = tostring(sDefault),
                TextSize           = 12,
                Font               = Enum.Font.GothamBold,
                TextColor3         = T.Accent,
                BackgroundTransparency = 1,
                Size               = UDim2.new(0.3, 0, 1, 0),
                Position           = UDim2.new(0.7, 0, 0, 0),
                TextXAlignment     = Enum.TextXAlignment.Right,
                Parent             = titleRow,
            })

            if sDesc ~= "" then
                New("TextLabel", {
                    Text               = sDesc,
                    TextSize           = 11,
                    Font               = Enum.Font.Gotham,
                    TextColor3         = T.TextSecondary,
                    BackgroundTransparency = 1,
                    Size               = UDim2.new(1, -12, 0, 13),
                    Position           = UDim2.new(0, 12, 0, 26),
                    TextXAlignment     = Enum.TextXAlignment.Left,
                    TextWrapped        = true,
                    Parent             = Frame,
                })
            end

            local trackY = sDesc ~= "" and 44 or 34
            local Track = New("Frame", {
                Size             = UDim2.new(1, -24, 0, 5),
                Position         = UDim2.new(0, 12, 0, trackY),
                BackgroundColor3 = T.Divider,
                BorderSizePixel  = 0,
                ClipsDescendants = true,
                Parent           = Frame,
            }, { Corner(3) })

            local Fill = New("Frame", {
                Size             = UDim2.new(0, 0, 1, 0),
                BackgroundColor3 = T.Accent,
                BorderSizePixel  = 0,
                Parent           = Track,
            }, { Corner(3) })

            -- Thumb dot
            local ThumbContainer = New("Frame", {
                Size             = UDim2.new(0, 5, 1, 0),
                Position         = UDim2.new(0, 0, 0, 0),
                BackgroundTransparency = 1,
                ClipsDescendants = false,
                Parent           = Track,
            })

            New("Frame", {
                Size             = UDim2.fromOffset(11, 11),
                Position         = UDim2.new(1, -5, 0.5, -5),
                BackgroundColor3 = Color3.fromRGB(255,255,255),
                BorderSizePixel  = 0,
                Parent           = ThumbContainer,
            }, { Corner(6), Stroke(T.Accent, 2, 0) })

            local function Round(n, factor)
                if factor == 0 then return math.floor(n + 0.5) end
                return math.floor(n / factor + 0.5) * factor
            end

            local function SetValue(v)
                value = math.clamp(Round(v, sRound == 0 and 1 or sRound), sMin, sMax)
                local pct = (value - sMin) / (sMax - sMin)
                Tween(Fill, { Size = UDim2.new(pct, 0, 1, 0) }, 0.1, Enum.EasingStyle.Linear)
                Tween(ThumbContainer, { Size = UDim2.new(pct, 5, 1, 0) }, 0.1, Enum.EasingStyle.Linear)
                ValLabel.Text = tostring(value)
                task.spawn(sCallback, value)
            end

            SetValue(sDefault)

            Track.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                end
            end)
            Track.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)
            UserInputService.InputChanged:Connect(function(inp)
                if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
                    local pct = math.clamp((inp.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    SetValue(sMin + (sMax - sMin) * pct)
                end
            end)

            local SliderObj = {}
            function SliderObj:Set(v) SetValue(v) end
            function SliderObj:Get() return value end
            return SliderObj
        end

