		BackgroundColor3 = C.Stroke, BorderSizePixel = 0, Parent = Sidebar,
	})

	local ContentScroll = new("ScrollingFrame", {
		Size                 = UDim2.new(1,-128,1,-42),
		Position             = UDim2.new(0,128,0,42),
