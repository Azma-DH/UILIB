local function Notify(cfg)
    cfg = cfg or {}
    local dur = math.max(cfg.Duration or 4, 1.5)

    local wrap = new("Frame",{
        Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundTransparency=1, Parent=NotifStack,
    })

    local box = new("Frame",{
        Size=UDim2.new(1,0,0,0), Position=UDim2.new(1,4,0,0),
        AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundColor3=D.notifBg, BorderSizePixel=0, Parent=wrap,
    },{
        rnd(8), uist(D.b1,1,0), upd(10,10,12,12), ull(4),
    })

    -- Accent left strip
    new("Frame",{
        Size=UDim2.new(0,2,1,0), AnchorPoint=Vector2.new(0,0),
        Position=UDim2.new(0,0,0,0), BackgroundColor3=D.acc,
        BorderSizePixel=0, ZIndex=2, Parent=box,
    },{rnd(2)})

    local tl = new("TextLabel",{
        Text=cfg.Title or "", TextSize=12, Font=Enum.Font.GothamBold,
        TextColor3=D.t1, BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,14), TextXAlignment=Enum.TextXAlignment.Left,
        LayoutOrder=0, Parent=box,
    })
    local dl = new("TextLabel",{
        Text=cfg.Desc or "", TextSize=11, Font=Enum.Font.Gotham,
        TextColor3=D.t2, BackgroundTransparency=1,
        Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y,
        TextXAlignment=Enum.TextXAlignment.Left, TextWrapped=true,
        LayoutOrder=1, Parent=box,
    })

    tw(box, {Position=UDim2.new(0,0,0,0)}, 0.28)
    task.delay(dur-0.45, function()
        tw(box, {BackgroundTransparency=0.55}, 0.2)
        tw(tl,  {TextTransparency=0.55}, 0.2)
        tw(dl,  {TextTransparency=0.65}, 0.2)
        task.wait(0.2)
        tw(box, {Position=UDim2.new(1,4,0,0)}, 0.25)
        task.wait(0.28) wrap:Destroy()
    end)
end

-- ─── Smooth drag ─────────────────────────────────────────────────────────────
local function makeDraggable(handle, frame)
    local drag, inp, mp, fp = false
    handle.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            drag=true mp=i.Position fp=frame.Position
            i.Changed:Connect(function()
                if i.UserInputState==Enum.UserInputState.End then drag=false end
            end)
        end
    end)
    handle.InputChanged:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseMovement then inp=i end
    end)
    UIS.InputChanged:Connect(function(i)
        if i==inp and drag then
            local d=i.Position-mp
            tw(frame,{Position=UDim2.new(fp.X.Scale,fp.X.Offset+d.X,fp.Y.Scale,fp.Y.Offset+d.Y)},0.08,Enum.EasingStyle.Linear)
        end
    end)
end

