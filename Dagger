function DaggerLib:Window(config)
    config         = config or {}
    local title    = config.Title   or "DaggerLib"
    local subtitle = config.Desc    or ""
    local keybind  = config.Keybind or Enum.KeyCode.LeftControl
    local winW, winH = 500, 380

    local WindowObj = {}

    -- Main frame
    local Main = New("Frame", {
        Name             = "DaggerMain",
        Size             = UDim2.fromOffset(winW, winH),
        Position         = UDim2.new(0.5, -winW/2, 0.5, -winH/2),
        BackgroundColor3 = T.Background,
        BorderSizePixel  = 0,
        ClipsDescendants = true,
        Parent           = ScreenGui,
    }, {
        Corner(10),
        Stroke(T.Stroke, 1, 0),
    })

    -- Topbar
    local Topbar = New("Frame", {
        Name             = "Topbar",
        Size             = UDim2.new(1, 0, 0, 40),
        BackgroundColor3 = T.Topbar,
        BorderSizePixel  = 0,
        Parent           = Main,
    }, {
        New("UICorner", { CornerRadius = UDim.new(0, 10) }),
        -- cover bottom rounded corners of topbar
        New("Frame", {
            Size             = UDim2.new(1, 0, 0, 10),
            Position         = UDim2.new(0, 0, 1, -10),
            BackgroundColor3 = T.Topbar,
            BorderSizePixel  = 0,
        }),
        Stroke(T.Stroke, 1, 0.6),
    })

    -- Title
    New("TextLabel", {
        Text               = title,
        TextSize           = 14,
        Font               = Enum.Font.GothamBold,
        TextColor3         = T.TextPrimary,
        BackgroundTransparency = 1,
        Size               = UDim2.new(0, 200, 1, 0),
        Position           = UDim2.new(0, 14, 0, 0),
        TextXAlignment     = Enum.TextXAlignment.Left,
        Parent             = Topbar,
    })

    -- Subtitle
    New("TextLabel", {
        Text               = subtitle,
        TextSize           = 11,
        Font               = Enum.Font.Gotham,
        TextColor3         = T.TextDim,
        BackgroundTransparency = 1,
        Size               = UDim2.new(0, 200, 1, 0),
        Position           = UDim2.new(0, 14, 0, 16),
        TextXAlignment     = Enum.TextXAlignment.Left,
        Parent             = Topbar,
    })

    -- Close button
    local CloseBtn = New("TextButton", {
        Text               = "тЬХ",
        TextSize           = 13,
        Font               = Enum.Font.GothamBold,
        TextColor3         = T.TextDim,
        BackgroundColor3   = T.Element,
        Size               = UDim2.fromOffset(26, 26),
        Position           = UDim2.new(1, -36, 0.5, -13),
        AutoButtonColor    = false,
        Parent             = Topbar,
    }, { Corner(6) })

    -- Minimise button
    local MinBtn = New("TextButton", {
        Text               = "тАФ",
        TextSize           = 13,
        Font               = Enum.Font.GothamBold,
        TextColor3         = T.TextDim,
        BackgroundColor3   = T.Element,
        Size               = UDim2.fromOffset(26, 26),
        Position           = UDim2.new(1, -66, 0.5, -13),
        AutoButtonColor    = false,
        Parent             = Topbar,
    }, { Corner(6) })

    MakeDraggable(Topbar, Main)

    -- Close/Minimise logic
    local minimised = false
    local hidden    = false

    CloseBtn.MouseButton1Click:Connect(function()
        Tween(Main, { Size = UDim2.fromOffset(winW, 0), Position = UDim2.new(Main.Position.X.Scale, Main.Position.X.Offset, Main.Position.Y.Scale, Main.Position.Y.Offset + winH/2) }, 0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
        task.wait(0.35)
        Main.Visible = false
        hidden = true
        Notify("UI Hidden", "Press " .. tostring(keybind.Name) .. " to reopen.", 5)
    end)

    MinBtn.MouseButton1Click:Connect(function()
        minimised = not minimised
        if minimised then
            Tween(Main, { Size = UDim2.fromOffset(winW, 40) }, 0.35, Enum.EasingStyle.Quint)
        else
            Tween(Main, { Size = UDim2.fromOffset(winW, winH) }, 0.35, Enum.EasingStyle.Quint)
        end
    end)

    UserInputService.InputBegan:Connect(function(inp, gp)
        if gp then return end
        if inp.KeyCode == keybind then
            Main.Visible = not Main.Visible
            if Main.Visible and minimised then
                minimised = false
                Tween(Main, { Size = UDim2.fromOffset(winW, winH) }, 0.35, Enum.EasingStyle.Quint)
            end
        end
    end)

    -- Hover effects on buttons
    for _, btn in ipairs({ CloseBtn, MinBtn }) do
        btn.MouseEnter:Connect(function()
            TweenQuad(btn, { BackgroundColor3 = T.ElementHover })
        end)
        btn.MouseLeave:Connect(function()
            TweenQuad(btn, { BackgroundColor3 = T.Element })
        end)
    end

    -- тФАтФА Layout: Sidebar + Content тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
    -- Sidebar (left, tabs)
    local Sidebar = New("Frame", {
        Name             = "Sidebar",
        Size             = UDim2.new(0, 130, 1, -40),
        Position         = UDim2.new(0, 0, 0, 40),
        BackgroundColor3 = T.Sidebar,
        BorderSizePixel  = 0,
        Parent           = Main,
    }, {
        -- Vertical divider line on right edge
        New("Frame", {
            Size             = UDim2.new(0, 1, 1, 0),
            Position         = UDim2.new(1, -1, 0, 0),
            BackgroundColor3 = T.Stroke,
            BorderSizePixel  = 0,
        }),
        Padding(8, 8, 0, 0),
        ListLayout(4),
    })

    -- Content area (right)
    local ContentArea = New("ScrollingFrame", {
        Name                  = "ContentArea",
        Size                  = UDim2.new(1, -130, 1, -40),
        Position              = UDim2.new(0, 130, 0, 40),
        BackgroundColor3      = T.Content,
        BorderSizePixel       = 0,
        ScrollBarThickness    = 3,
        ScrollBarImageColor3  = T.Accent,
        CanvasSize            = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize   = Enum.AutomaticSize.Y,
        Parent                = Main,
    }, {
        Padding(10, 10, 10, 10),
