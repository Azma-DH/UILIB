		BackgroundColor3=C.Border,BorderSizePixel=0,ZIndex=3,Parent=Top})
	rnd(10):Clone().Parent=Top

	-- Hub name — left side with small accent dot
	mk("Frame",{Size=UDim2.fromOffset(3,3),Position=UDim2.new(0,12,0.5,-1),
		BackgroundColor3=C.AccentHi,BorderSizePixel=0,ZIndex=3,Parent=Top},{rnd(4)})
	mk("TextLabel",{Text=title,TextSize=13,Font=Enum.Font.GothamBold,
		TextColor3=C.TxtA,BackgroundTransparency=1,
		Size=UDim2.new(0,180,1,0),Position=UDim2.new(0,22,0,0),
		TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=Top})
	mk("TextLabel",{Text=sub,TextSize=10,Font=Enum.Font.Gotham,
		TextColor3=C.TxtC,BackgroundTransparency=1,
		Size=UDim2.new(0,180,1,0),Position=UDim2.new(0,22,0,17),
		TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=Top})

	-- topbar icon buttons
	local function topBtn(icon, xOff)
		local b = mk("TextButton",{
			Text=icon,TextSize=11,Font=Enum.Font.GothamBold,
			TextColor3=C.TxtC,BackgroundColor3=C.Panel,
			Size=UDim2.fromOffset(22,22),Position=UDim2.new(1,xOff,0.5,-11),
			AutoButtonColor=false,BorderSizePixel=0,ZIndex=4,Parent=Top,
		},{rnd(5),str(C.Border,1,0.4)})
		b.MouseEnter:Connect(function() tw(b,{TextColor3=C.TxtA,BackgroundColor3=C.Row},0.15) end)
		b.MouseLeave:Connect(function() tw(b,{TextColor3=C.TxtC,BackgroundColor3=C.Panel},0.15) end)
		return b
	end
	local CloseB = topBtn("✕",-32)
	local MinB   = topBtn("—",-58)

	drag(Top,Main)

	local mini=false
	CloseB.MouseButton1Click:Connect(function()
		tw(Main,{Size=UDim2.fromOffset(W,0)},0.22,Enum.EasingStyle.Quint,Enum.EasingDirection.In)
		task.wait(0.25) Main.Visible=false
		Notify("Hidden","Press "..kb.Name.." to reopen.",4)
	end)
	MinB.MouseButton1Click:Connect(function()
		mini=not mini
		tw(Main,{Size=UDim2.fromOffset(W,mini and 40 or H)},0.28,Enum.EasingStyle.Quint)
	end)
	UIS.InputBegan:Connect(function(i,gp)
		if gp then return end
		if i.KeyCode==kb then
			Main.Visible=not Main.Visible
			if Main.Visible and mini then mini=false tw(Main,{Size=UDim2.fromOffset(W,H)},0.28) end
		end
	end)

	-- ── Sidebar ──
	-- Sidebar is narrower (110px) and slightly lighter than panel
	local SB = mk("Frame",{
		Size=UDim2.new(0,112,1,-40),Position=UDim2.new(0,0,0,40),
		BackgroundColor3=C.Bar,BorderSizePixel=0,Parent=Main,
	},{pdg(8,8,6,6),lst(2)})
	-- right border line
	mk("Frame",{Size=UDim2.new(0,1,1,0),Position=UDim2.new(1,-1,0,0),
		BackgroundColor3=C.Border,BorderSizePixel=0,Parent=SB})

	-- ── Content scroll ──
	local CS = mk("ScrollingFrame",{
		Size=UDim2.new(1,-112,1,-40),Position=UDim2.new(0,112,0,40),
		BackgroundColor3=C.Base,BorderSizePixel=0,
		ScrollBarThickness=2,ScrollBarImageColor3=C.AccentGlo,
		ScrollingDirection=Enum.ScrollingDirection.Y,
		CanvasSize=UDim2.new(0,0,0,0),Parent=Main,
	},{pdg(10,10,10,10),lst(5)})

	local cLL=CS:FindFirstChildOfClass("UIListLayout")
	cLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		CS.CanvasSize=UDim2.new(0,0,0,cLL.AbsoluteContentSize.Y+20)
	end)

	-- ── Tab system ──
	local tabs={} local first=true local active=nil

	local function deactivate()
		for _,t in ipairs(tabs) do
			t.pg.Visible=false
			tw(t.btn,{BackgroundColor3=C.Bar},0.15)
			tw(t.lbl,{TextColor3=C.TxtC},0.15)
			t.bar.Visible=false
		end
	end

	function Win:Tab(cfg)
		cfg=cfg or {}
		local name=cfg.Title or "Tab"

		-- sidebar button — clean text-only style like Orca
		local btn = mk("TextButton",{
			Size=UDim2.new(1,0,0,28),BackgroundColor3=C.Bar,
			AutoButtonColor=false,Text="",BorderSizePixel=0,Parent=SB,
		},{rnd(5)})

		-- left accent bar (hidden when inactive)
		local abar = mk("Frame",{
			Size=UDim2.new(0,2,0.6,0),Position=UDim2.new(0,0,0.2,0),
			BackgroundColor3=C.AccentHi,BorderSizePixel=0,Visible=false,Parent=btn,
		},{rnd(2)})

		local lbl = mk("TextLabel",{
			Text=name,TextSize=11,Font=Enum.Font.GothamSemibold,
			TextColor3=C.TxtC,BackgroundTransparency=1,
			Size=UDim2.new(1,-14,1,0),Position=UDim2.new(0,14,0,0),
			TextXAlignment=Enum.TextXAlignment.Left,Parent=btn,
		})

		-- page
		local pg = mk("Frame",{
			Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
			BackgroundTransparency=1,Visible=false,Parent=CS,
		},{lst(5)})

		local entry={btn=btn,lbl=lbl,bar=abar,pg=pg}
		table.insert(tabs,entry)

		local function activate()
			deactivate()
			pg.Visible=true
			tw(btn,{BackgroundColor3=C.RowHov},0.15)
			tw(lbl,{TextColor3=C.TxtA},0.15)
			abar.Visible=true
			active=entry
			CS.CanvasPosition=Vector2.zero
		end
		if first then first=false activate() end

		btn.MouseButton1Click:Connect(activate)
		btn.MouseEnter:Connect(function() if active~=entry then tw(btn,{BackgroundColor3=C.Row},0.12) end end)
		btn.MouseLeave:Connect(function() if active~=entry then tw(btn,{BackgroundColor3=C.Bar},0.12) end end)

		-- ── Elements ──────────────────────────────────────────────────────────
		local T={}

		-- base row — very subtle, dark with a fine border
		local function row(h)
			return mk("Frame",{
				Size=UDim2.new(1,0,0,h or 34),BackgroundColor3=C.Row,
				BorderSizePixel=0,ClipsDescendants=false,Parent=pg,
			},{rnd(6),str(C.Border,1,0.5)})
		end

		-- Section: small uppercase label like Orca's category headers
		function T:Section(cfg)
			cfg=cfg or {}
			local n=(cfg.Title or ""):upper()
			local f=mk("Frame",{Size=UDim2.new(1,0,0,22),BackgroundTransparency=1,Parent=pg})
			mk("TextLabel",{Text=n,TextSize=9,Font=Enum.Font.GothamBold,
				TextColor3=C.TxtC,BackgroundTransparency=1,
				Size=UDim2.new(1,0,1,0),Position=UDim2.new(0,2,0,0),
				TextXAlignment=Enum.TextXAlignment.Left,Parent=f})
		end

		-- Button
		function T:Button(cfg)
			cfg=cfg or {}
			local bn=cfg.Title or "Button"
			local bd=cfg.Desc  or ""
			local cb=cfg.Callback or function()end
			local h=bd~="" and 46 or 32
			local f=row(h)
			-- left accent line on hover/press
			local al=mk("Frame",{Size=UDim2.new(0,2,0.6,0),Position=UDim2.new(0,0,0.2,0),
				BackgroundColor3=C.Accent,BorderSizePixel=0,Visible=false,Parent=f},{rnd(2)})
			mk("TextLabel",{Text=bn,TextSize=12,Font=Enum.Font.GothamSemibold,
				TextColor3=C.TxtA,BackgroundTransparency=1,
				Size=UDim2.new(1,-40,0,14),Position=UDim2.new(0,12,0,bd~="" and 7 or 10),
				TextXAlignment=Enum.TextXAlignment.Left,Parent=f})
			if bd~="" then
				mk("TextLabel",{Text=bd,TextSize=10,Font=Enum.Font.Gotham,
					TextColor3=C.TxtC,BackgroundTransparency=1,
					Size=UDim2.new(1,-40,0,12),Position=UDim2.new(0,12,0,23),
					TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=f})
			end
			-- subtle right chevron
			mk("TextLabel",{Text="›",TextSize=14,Font=Enum.Font.GothamBold,
				TextColor3=C.TxtC,BackgroundTransparency=1,
				Size=UDim2.new(0,20,1,0),Position=UDim2.new(1,-24,0,0),
				TextXAlignment=Enum.TextXAlignment.Center,Parent=f})
			local cl=mk("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false,Parent=f})
			cl.MouseEnter:Connect(function()  tw(f,{BackgroundColor3=C.RowHov},0.1) al.Visible=true end)
			cl.MouseLeave:Connect(function()  tw(f,{BackgroundColor3=C.Row},0.1) al.Visible=false end)
			cl.MouseButton1Down:Connect(function() tw(f,{BackgroundColor3=C.RowPrs},0.07) end)
			cl.MouseButton1Up:Connect(function()   tw(f,{BackgroundColor3=C.RowHov},0.1) al.Visible=true task.spawn(cb) end)
		end

		-- Toggle — slim iOS-style pill
		function T:Toggle(cfg)
			cfg=cfg or {}
			local tn=cfg.Title or "Toggle"
			local td=cfg.Desc  or ""
			local tv=cfg.Value if tv==nil then tv=false end
			local cb=cfg.Callback or function()end
			local on=tv
			local h=td~="" and 46 or 32
			local f=row(h)
			mk("TextLabel",{Text=tn,TextSize=12,Font=Enum.Font.GothamSemibold,
				TextColor3=C.TxtA,BackgroundTransparency=1,
				Size=UDim2.new(1,-60,0,14),Position=UDim2.new(0,12,0,td~="" and 7 or 10),
				TextXAlignment=Enum.TextXAlignment.Left,Parent=f})
			if td~="" then
				mk("TextLabel",{Text=td,TextSize=10,Font=Enum.Font.Gotham,
					TextColor3=C.TxtC,BackgroundTransparency=1,
					Size=UDim2.new(1,-60,0,12),Position=UDim2.new(0,12,0,23),
					TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=f})
			end
			-- pill track
			local tr=mk("Frame",{Size=UDim2.fromOffset(34,18),Position=UDim2.new(1,-46,0.5,-9),
				BackgroundColor3=C.TrkOff,BorderSizePixel=0,Parent=f},{rnd(9)})
			-- thumb circle
			local th=mk("Frame",{Size=UDim2.fromOffset(12,12),Position=UDim2.fromOffset(3,3),
				BackgroundColor3=C.ThumbOff,BorderSizePixel=0,Parent=tr},{rnd(6)})
			local function set(v,silent)
				on=v
				if v then
					tw(tr,{BackgroundColor3=C.TrkOn},0.2)
					tw(th,{Position=UDim2.fromOffset(19,3),BackgroundColor3=C.ThumbOn},0.2)
				else
					tw(tr,{BackgroundColor3=C.TrkOff},0.2)
					tw(th,{Position=UDim2.fromOffset(3,3),BackgroundColor3=C.ThumbOff},0.2)
				end
				if not silent then task.spawn(cb,v) end
			end
			set(tv,true)
			local cl=mk("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false,Parent=f})
			cl.MouseEnter:Connect(function() tw(f,{BackgroundColor3=C.RowHov},0.1) end)
			cl.MouseLeave:Connect(function() tw(f,{BackgroundColor3=C.Row},0.1) end)
			cl.MouseButton1Up:Connect(function() set(not on) end)
			local o={}
			function o:Set(v) set(v) end
			function o:Get() return on end
			return o
		end

		-- Slider — thin track, no thumb box, just a moving circle
		function T:Slider(cfg)
			cfg=cfg or {}
			local sn=cfg.Title    or "Slider"
			local sd=cfg.Desc     or ""
			local smi=cfg.Min     or 0
			local sma=cfg.Max     or 100
			local sv=cfg.Value    or smi
			local sr=cfg.Rounding or 0
			local cb=cfg.Callback or function()end
			local val=sv local dragging=false
			local h=sd~="" and 56 or 44
			local f=row(h)
			-- title + value display
			local tr=mk("Frame",{Size=UDim2.new(1,-20,0,14),Position=UDim2.new(0,10,0,8),
				BackgroundTransparency=1,Parent=f})
			mk("TextLabel",{Text=sn,TextSize=12,Font=Enum.Font.GothamSemibold,
				TextColor3=C.TxtA,BackgroundTransparency=1,
				Size=UDim2.new(0.7,0,1,0),TextXAlignment=Enum.TextXAlignment.Left,Parent=tr})
			local vl=mk("TextLabel",{Text=tostring(sv),TextSize=11,Font=Enum.Font.GothamBold,
				TextColor3=C.AccentHi,BackgroundTransparency=1,
				Size=UDim2.new(0.3,0,1,0),Position=UDim2.new(0.7,0,0,0),
				TextXAlignment=Enum.TextXAlignment.Right,Parent=tr})
			if sd~="" then
				mk("TextLabel",{Text=sd,TextSize=10,Font=Enum.Font.Gotham,TextColor3=C.TxtC,
					BackgroundTransparency=1,Size=UDim2.new(1,-20,0,11),Position=UDim2.new(0,10,0,24),
					TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=f})
			end
			local ty=sd~="" and 40 or 30
			-- track background — very thin line style
			local tbg=mk("Frame",{Size=UDim2.new(1,-20,0,4),Position=UDim2.new(0,10,0,ty),
				BackgroundColor3=C.TrkOff,BorderSizePixel=0,ClipsDescendants=false,Parent=f},{rnd(2)})
			-- filled portion
			local fill=mk("Frame",{Size=UDim2.new(0,0,1,0),BackgroundColor3=C.Accent,
				BorderSizePixel=0,Parent=tbg},{rnd(2)})
			-- thumb dot — sits on top of fill end
			local dot=mk("Frame",{Size=UDim2.fromOffset(10,10),AnchorPoint=Vector2.new(0.5,0.5),
				Position=UDim2.new(0,0,0.5,0),BackgroundColor3=C.AccentHi,
				BorderSizePixel=0,ZIndex=5,Parent=fill},{rnd(5)})

			local function rn(n,fac) if fac==0 then return math.floor(n+0.5) end return math.floor(n/fac+0.5)*fac end
			local function setv(v)
				val=math.clamp(rn(v,sr),smi,sma)
				local p=(val-smi)/math.max(sma-smi,0.001)
				tw(fill,{Size=UDim2.new(p,0,1,0)},0.06,Enum.EasingStyle.Linear)
				vl.Text=tostring(val)
				task.spawn(cb,val)
			end
			setv(sv)
			tbg.InputBegan:Connect(function(i)
				if i.UserInputType==Enum.UserInputType.MouseButton1 then
					dragging=true
					local p=math.clamp((i.Position.X-tbg.AbsolutePosition.X)/tbg.AbsoluteSize.X,0,1)
					setv(smi+(sma-smi)*p)
				end
			end)
			UIS.InputChanged:Connect(function(i)
				if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then
					local p=math.clamp((i.Position.X-tbg.AbsolutePosition.X)/tbg.AbsoluteSize.X,0,1)
					setv(smi+(sma-smi)*p)
				end
			end)
			UIS.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end end)
			local o={}
			function o:Set(v) setv(v) end
			function o:Get() return val end
			return o
		end

		-- Textbox
		function T:Textbox(cfg)
			cfg=cfg or {}
			local tn=cfg.Title or "Input"
			local td=cfg.Desc  or ""
			local ph=cfg.Placeholder or "Type here..."
			local dv=cfg.Value or ""
			local cl=cfg.ClearTextOnFocus if cl==nil then cl=false end
			local cb=cfg.Callback or function()end
			local h=td~="" and 58 or 46
			local f=row(h)
			mk("TextLabel",{Text=tn,TextSize=12,Font=Enum.Font.GothamSemibold,
				TextColor3=C.TxtA,BackgroundTransparency=1,
				Size=UDim2.new(1,-20,0,14),Position=UDim2.new(0,10,0,6),
				TextXAlignment=Enum.TextXAlignment.Left,Parent=f})
			if td~="" then
				mk("TextLabel",{Text=td,TextSize=10,Font=Enum.Font.Gotham,TextColor3=C.TxtC,
					BackgroundTransparency=1,Size=UDim2.new(1,-20,0,11),Position=UDim2.new(0,10,0,21),
					TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=f})
			end
			local iy=td~="" and 35 or 24
			local ibg=mk("Frame",{Size=UDim2.new(1,-20,0,20),Position=UDim2.new(0,10,0,iy),
				BackgroundColor3=C.Base,BorderSizePixel=0,Parent=f},{rnd(4),str(C.Border,1,0.3)})
			local ibs=ibg:FindFirstChildOfClass("UIStroke")
			local ib=mk("TextBox",{Size=UDim2.new(1,-10,1,0),Position=UDim2.new(0,6,0,0),
				BackgroundTransparency=1,Text=dv,PlaceholderText=ph,PlaceholderColor3=C.TxtC,
				TextSize=11,Font=Enum.Font.Gotham,TextColor3=C.TxtA,
				TextXAlignment=Enum.TextXAlignment.Left,ClearTextOnFocus=cl,Parent=ibg})
			ib.Focused:Connect(function()   tw(ibg,{BackgroundColor3=C.RowHov},0.15) if ibs then tw(ibs,{Color=C.Accent},0.15) end end)
			ib.FocusLost:Connect(function() tw(ibg,{BackgroundColor3=C.Base},0.15)   if ibs then tw(ibs,{Color=C.Border},0.15) end task.spawn(cb,ib.Text) end)
		end

		-- Dropdown
		function T:Dropdown(cfg)
			cfg=cfg or {}
			local dn=cfg.Title or "Dropdown"
			local dl=cfg.List  or {}
			local dv=cfg.Value or ""
			local cb=cfg.Callback or function()end
			local sel=dv local open=false
			local BH=32 local IH=24

			local outer=mk("Frame",{Size=UDim2.new(1,0,0,BH),BackgroundColor3=C.Row,
				BorderSizePixel=0,ClipsDescendants=false,Parent=pg},{rnd(6),str(C.Border,1,0.5)})
			local hdr=mk("Frame",{Size=UDim2.new(1,0,0,BH),BackgroundTransparency=1,
				ClipsDescendants=true,Parent=outer})
			mk("TextLabel",{Text=dn,TextSize=12,Font=Enum.Font.GothamSemibold,
				TextColor3=C.TxtA,BackgroundTransparency=1,
				Size=UDim2.new(0.55,0,1,0),Position=UDim2.new(0,10,0,0),
				TextXAlignment=Enum.TextXAlignment.Left,Parent=hdr})
			local sl=mk("TextLabel",{
				Text=sel~="" and sel or "—",TextSize=11,Font=Enum.Font.Gotham,
				TextColor3=C.TxtB,BackgroundTransparency=1,
				Size=UDim2.new(0.35,0,1,0),Position=UDim2.new(0.55,0,0,0),
				TextXAlignment=Enum.TextXAlignment.Right,Parent=hdr})
			local ar=mk("TextLabel",{Text="›",TextSize=13,Font=Enum.Font.GothamBold,
				TextColor3=C.TxtC,BackgroundTransparency=1,
				Size=UDim2.new(0,20,1,0),Position=UDim2.new(1,-24,0,0),
				TextXAlignment=Enum.TextXAlignment.Center,Rotation=90,Parent=hdr})

			local lp=mk("Frame",{Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,0,BH+1),
				BackgroundColor3=C.RowHov,BorderSizePixel=0,ClipsDescendants=true,
				ZIndex=10,Parent=outer},{rnd(6),str(C.Border,1,0.5),pdg(3,3,4,4),lst(2)})

			local function ch() return math.min(#dl*IH+6,140) end
			local function bl()
				for _,v in ipairs(lp:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
				for _,opt in ipairs(dl) do
					local isSel=opt==sel
					local b=mk("TextButton",{Text=opt,TextSize=11,
						Font=isSel and Enum.Font.GothamBold or Enum.Font.Gotham,
						TextColor3=isSel and C.AccentHi or C.TxtB,
						BackgroundColor3=isSel and C.AccentGlo or C.Row,
						Size=UDim2.new(1,0,0,IH-2),AutoButtonColor=false,
						TextXAlignment=Enum.TextXAlignment.Left,ZIndex=11,Parent=lp,
					},{rnd(4),pdg(0,0,8,0)})
					b.MouseEnter:Connect(function() if opt~=sel then tw(b,{BackgroundColor3=C.RowPrs},0.1) end end)
					b.MouseLeave:Connect(function() if opt~=sel then tw(b,{BackgroundColor3=C.Row},0.1) end end)
					b.MouseButton1Click:Connect(function() sel=opt sl.Text=opt bl() task.spawn(cb,opt) end)
				end
			end
			bl()

			local function so(s)
				open=s local th=s and ch() or 0
				tw(lp,{Size=UDim2.new(1,0,0,th)},0.18)
				tw(outer,{Size=UDim2.new(1,0,0,BH+(s and th+2 or 0))},0.18)
				tw(ar,{Rotation=s and 270 or 90},0.18)
			end
			local hc=mk("TextButton",{Size=UDim2.new(1,0,0,BH),BackgroundTransparency=1,Text="",AutoButtonColor=false,Parent=hdr})
			hc.MouseButton1Click:Connect(function() so(not open) end)
			hc.MouseEnter:Connect(function() tw(outer,{BackgroundColor3=C.RowHov},0.1) end)
			hc.MouseLeave:Connect(function() tw(outer,{BackgroundColor3=C.Row},0.1) end)

			local o={Value=sel}
			function o:UpdateList(list) dl=list bl() if open then local th=ch() tw(lp,{Size=UDim2.new(1,0,0,th)},0.15) tw(outer,{Size=UDim2.new(1,0,0,BH+th+2)},0.15) end end
			function o:SetValue(v) sel=v sl.Text=v~="" and v or "—" o.Value=v bl() end
			function o:GetValue() return sel end
			return o
		end

		-- Code display
		function T:Code(cfg)
			cfg=cfg or {}
			local ct=cfg.Title or "Info"
			local cc=cfg.Code  or ""
			local f=mk("Frame",{Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
				BackgroundColor3=C.Row,BorderSizePixel=0,ClipsDescendants=false,Parent=pg,
			},{rnd(6),str(C.Border,1,0.5),pdg(7,8,10,10),lst(3)})
			mk("TextLabel",{Text=ct:upper(),TextSize=9,Font=Enum.Font.GothamBold,
				TextColor3=C.TxtC,BackgroundTransparency=1,
				Size=UDim2.new(1,0,0,11),TextXAlignment=Enum.TextXAlignment.Left,
				LayoutOrder=0,Parent=f})
			local body=mk("TextLabel",{Text=cc,TextSize=11,Font=Enum.Font.Code,
				TextColor3=C.TxtB,BackgroundTransparency=1,Size=UDim2.new(1,0,0,0),
				AutomaticSize=Enum.AutomaticSize.Y,TextXAlignment=Enum.TextXAlignment.Left,
				TextWrapped=true,LayoutOrder=1,Parent=f})
			local o={}
			function o:SetCode(v) body.Text=tostring(v) end
			return o
		end

		-- Label
		function T:Label(cfg)
			cfg=cfg or {}
			local l=mk("TextLabel",{Text=cfg.Text or "",TextSize=11,Font=Enum.Font.Gotham,
				TextColor3=C.TxtC,BackgroundTransparency=1,
				Size=UDim2.new(1,0,0,16),TextXAlignment=Enum.TextXAlignment.Left,
				TextWrapped=true,Parent=pg})
			local o={}
			function o:Set(v) l.Text=tostring(v) end
			return o
		end

		-- Line
		function T:Line()
			mk("Frame",{Size=UDim2.new(1,0,0,1),BackgroundColor3=C.Border,
				BorderSizePixel=0,Parent=pg})
		end

		return T
	end

	function Win:Notify(cfg) cfg=cfg or {} Notify(cfg.Title,cfg.Desc,cfg.Time) end
	function Win:Line() end
	return Win
end

DaggerLib.Notify = Notify
return DaggerLib
