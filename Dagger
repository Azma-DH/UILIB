		tween(Main,{Size=UDim2.fromOffset(W,0)},0.25,Enum.EasingStyle.Quint,Enum.EasingDirection.In)
		task.wait(0.28)
		Main.Visible = false
		Notify("UI Hidden","Press "..keybind.Name.." to reopen.",4)
	end)
