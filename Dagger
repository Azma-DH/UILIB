local function ShowNotify(cfg)
    cfg = cfg or {}
    local dur = math.max(cfg.Duration or 4, 1.5)

    local wrap = New("Frame", {
        Size              = UDim2.new(1, 0, 0, 0),
        AutomaticSize     = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Parent            = NotifHolder,
    })

    local box = New("Frame", {
        Size             = UDim2.new(1, 0, 0, 0),
        Position         = UDim2.new(1, 8, 0, 0),
        AutomaticSize    = Enum.AutomaticSize.Y,
        BackgroundColor3 = C.NotifBg,
        BorderSizePixel  = 0,
        Parent           = wrap,
    }, {
        Corner(8),
        Stroke(C.Accent, 1, 0.5),
        Pad(10, 10, 14, 14),
        List(3),
    })

    -- teal left accent bar
    New("Frame", {
        Size             = UDim2.new(0, 2, 1, 0),
        Position         = UDim2.new(0, 0, 0, 0),
        BackgroundColor3 = C.Accent,
        BorderSizePixel  = 0,
        ZIndex           = 2,
        Parent           = box,
    }, { Corner(2) })

    local tl = New("TextLabel", {
        Text               = cfg.Title or "",
        TextSize           = 13,
        Font               = Enum.Font.GothamBold,
        TextColor3         = C.TxtTitle,
        BackgroundTransparency = 1,
        Size               = UDim2.new(1, 0, 0, 15),
        TextXAlignment     = Enum.TextXAlignment.Left,
        LayoutOrder        = 0,
        Parent             = box,
    })
    local dl = New("TextLabel", {
        Text               = cfg.Desc or "",
        TextSize           = 11,
        Font               = Enum.Font.Gotham,
        TextColor3         = C.TxtDesc,
        BackgroundTransparency = 1,
        Size               = UDim2.new(1, 0, 0, 0),
        AutomaticSize      = Enum.AutomaticSize.Y,
        TextXAlignment     = Enum.TextXAlignment.Left,
        TextWrapped        = true,
        LayoutOrder        = 1,
        Parent             = box,
    })

    Tween(box, { Position = UDim2.new(0, 0, 0, 0) }, 0.3)

    task.delay(dur - 0.5, function()
        Tween(box, { BackgroundTransparency = 0.6 }, 0.22)
        Tween(tl,  { TextTransparency = 0.6 }, 0.22)
        Tween(dl,  { TextTransparency = 0.7 }, 0.22)
        task.wait(0.22)
        Tween(box, { Position = UDim2.new(1, 8, 0, 0) }, 0.28)
        task.wait(0.32)
        wrap:Destroy()
    end)
end

-- ─── Drag ────────────────────────────────────────────────────────────────────
local function MakeDraggable(handle, frame)
    local dragging, dragInput, mousePos, framePos = false
    handle.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging  = true
            mousePos  = inp.Position
            framePos  = frame.Position
            inp.Changed:Connect(function()
                if inp.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    handle.InputChanged:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseMovement then dragInput = inp end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if inp == dragInput and dragging then
            local delta = inp.Position - mousePos
            Tween(frame, {
                Position = UDim2.new(
                    framePos.X.Scale, framePos.X.Offset + delta.X,
                    framePos.Y.Scale, framePos.Y.Offset + delta.Y
                )
            }, 0.07)
        end
    end)
end

-- ─── Library ─────────────────────────────────────────────────────────────────
local DaggerLib = {}

function DaggerLib:Window(cfg)
    cfg         = cfg or {}
    local title   = cfg.Title   or "Hub"
    local version = cfg.Version or ""
    local key     = cfg.Key     or Enum.KeyCode.LeftControl

    -- Orca proportions: sidebar ~180px, rest is content
    local W, H  = 640, 460
    local SBW   = 185   -- sidebar width
    local Win   = {}
    Win.Notify  = ShowNotify

    -- ── Main frame ──────────────────────────────────────────────────────────
    local Main = New("Frame", {
        Name             = "DaggerMain",
        Size             = UDim2.fromOffset(W, H),
        Position         = UDim2.new(0.5, -W/2, 0.5, -H/2),
        BackgroundColor3 = C.Win,
        BorderSizePixel  = 0,
        ClipsDescendants = true,
        Parent           = Gui,
    }, { Corner(12) })

    -- ── Sidebar ─────────────────────────────────────────────────────────────
    local Sidebar = New("Frame", {
        Name             = "Sidebar",
        Size             = UDim2.new(0, SBW, 1, 0),
        BackgroundColor3 = C.Sidebar,
        BorderSizePixel  = 0,
        Parent           = Main,
    })

    -- Title area at top of sidebar — like Orca's "Orca 0.2"
    local TitleFrame = New("Frame", {
        Size             = UDim2.new(1, 0, 0, 58),
        BackgroundTransparency = 1,
        Parent           = Sidebar,
    })
    -- Big bold hub name
    New("TextLabel", {
        Text               = title,
        TextSize           = 26,
        Font               = Enum.Font.GothamBlack,
        TextColor3         = C.TxtTitle,
        BackgroundTransparency = 1,
        Size               = UDim2.new(1, -14, 1, 0),
        Position           = UDim2.new(0, 14, 0, 0),
        TextXAlignment     = Enum.TextXAlignment.Left,
        TextYAlignment     = Enum.TextYAlignment.Center,
        Parent             = TitleFrame,
    })
    -- Version tag — small teal next to title
    if version ~= "" then
        New("TextLabel", {
            Text               = version,
            TextSize           = 14,
            Font               = Enum.Font.GothamBold,
            TextColor3         = C.Accent,
            BackgroundTransparency = 1,
            -- Position it to the right of the title — approximate
            Size               = UDim2.new(0, 60, 0, 20),
            Position           = UDim2.new(0, 14 + (#title * 14), 0, 28),
            TextXAlignment     = Enum.TextXAlignment.Left,
            Parent             = TitleFrame,
        })
    end

    -- Divider below title
    New("Frame", {
        Size             = UDim2.new(1, -20, 0, 1),
        Position         = UDim2.new(0, 10, 0, 58),
        BackgroundColor3 = C.Divider,
        BorderSizePixel  = 0,
        Parent           = Sidebar,
    })

    -- Tab list inside sidebar
    local TabList = New("Frame", {
        Size             = UDim2.new(1, 0, 1, -68),
        Position         = UDim2.new(0, 0, 0, 68),
        BackgroundTransparency = 1,
        Parent           = Sidebar,
    }, { Pad(6, 6, 10, 10), List(3) })

    -- ── Content area ─────────────────────────────────────────────────────────
    local ContentScroll = New("ScrollingFrame", {
        Name                 = "Content",
        Size                 = UDim2.new(1, -SBW, 1, 0),
        Position             = UDim2.new(0, SBW, 0, 0),
        BackgroundColor3     = C.Content,
        BorderSizePixel      = 0,
        ScrollBarThickness   = 3,
        ScrollBarImageColor3 = C.Accent,
        ScrollingDirection   = Enum.ScrollingDirection.Y,
        CanvasSize           = UDim2.new(0, 0, 0, 0),
        Parent               = Main,
    }, { Pad(8, 12, 0, 0), List(0) })

    -- Auto-resize canvas
    local cLayout = ContentScroll:FindFirstChildOfClass("UIListLayout")
    cLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        ContentScroll.CanvasSize = UDim2.new(0, 0, 0, cLayout.AbsoluteContentSize.Y + 20)
    end)

    -- Drag by sidebar (only the title area, feels natural)
    MakeDraggable(TitleFrame, Main)

    -- Keybind toggle
    local minimised = false
    UserInputService.InputBegan:Connect(function(inp, gp)
        if gp then return end
        if inp.KeyCode == key then
            Main.Visible = not Main.Visible
            if Main.Visible and minimised then
                minimised = false
                Tween(Main, { Size = UDim2.fromOffset(W, H) }, 0.25)
            end
        end
    end)

    -- ── Tab builder ───────────────────────────────────────────────────────────
    local allTabs  = {}
    local firstTab = true
    local activeTab = nil

    local function DeactivateAll()
        for _, t in ipairs(allTabs) do
            t.page.Visible = false
            -- remove pill
            Tween(t.pill, { BackgroundTransparency = 1 }, 0.15)
            Tween(t.lbl,  { TextColor3 = C.TxtDim }, 0.15)
            if t.ico then Tween(t.ico, { TextColor3 = C.TxtDim }, 0.15) end
        end
    end

    function Win:Tab(tabCfg)
        tabCfg = tabCfg or {}
        local tabName = tabCfg.Title or "Tab"
        local tabIcon = tabCfg.Icon  or ""

        -- ── Sidebar button ──────────────────────────────────────────────────
        -- Outer container for the tab button
        local TabBtn = New("TextButton", {
            Size             = UDim2.new(1, 0, 0, 34),
            BackgroundTransparency = 1,
            Text             = "",
            AutoButtonColor  = false,
            BorderSizePixel  = 0,
            Parent           = TabList,
        }, { Corner(8) })

        -- Pill background (hidden when inactive, teal when active)
        local Pill = New("Frame", {
            Size             = UDim2.new(1, 0, 1, 0),
            BackgroundColor3 = C.AccentPill,
            BackgroundTransparency = 1, -- hidden by default
            BorderSizePixel  = 0,
            Parent           = TabBtn,
        }, { Corner(8) })

        -- Icon
        local IcoLbl = nil
        local textOffsetX = 10
        if tabIcon ~= "" then
            IcoLbl = New("TextLabel", {
                Text               = tabIcon,
                TextSize           = 14,
                Font               = Enum.Font.GothamSemibold,
                TextColor3         = C.TxtDim,
                BackgroundTransparency = 1,
                Size               = UDim2.fromOffset(22, 34),
                Position           = UDim2.new(0, 8, 0, 0),
                TextXAlignment     = Enum.TextXAlignment.Left,
                TextYAlignment     = Enum.TextYAlignment.Center,
                Parent             = TabBtn,
            })
            textOffsetX = 32
        end

        -- Tab name label
        local TabLbl = New("TextLabel", {
            Text               = tabName,
            TextSize           = 13,
            Font               = Enum.Font.GothamSemibold,
            TextColor3         = C.TxtDim,
            BackgroundTransparency = 1,
            Size               = UDim2.new(1, -textOffsetX - 6, 1, 0),
            Position           = UDim2.new(0, textOffsetX, 0, 0),
            TextXAlignment     = Enum.TextXAlignment.Left,
            TextYAlignment     = Enum.TextYAlignment.Center,
            Parent             = TabBtn,
        })

        -- Page (all rows for this tab live here)
        local Page = New("Frame", {
            Size          = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            Visible       = false,
            Parent        = ContentScroll,
        }, { List(0) })

        local entry = {
            btn  = TabBtn,
            pill = Pill,
            lbl  = TabLbl,
            ico  = IcoLbl,
            page = Page,
        }
        table.insert(allTabs, entry)

        local function Activate()
            DeactivateAll()
            Page.Visible = true
            -- Show pill
            Tween(Pill,   { BackgroundTransparency = 0 }, 0.15)
            Tween(TabLbl, { TextColor3 = C.TxtActive }, 0.15)
            if IcoLbl then Tween(IcoLbl, { TextColor3 = C.Accent }, 0.15) end
            activeTab = entry
            ContentScroll.CanvasPosition = Vector2.zero
        end

        TabBtn.MouseButton1Click:Connect(Activate)
        TabBtn.MouseEnter:Connect(function()
            if activeTab ~= entry then
                Tween(Pill, { BackgroundTransparency = 0.85 }, 0.12)
                Pill.BackgroundColor3 = C.RowHov
            end
        end)
        TabBtn.MouseLeave:Connect(function()
            if activeTab ~= entry then
                Tween(Pill, { BackgroundTransparency = 1 }, 0.12)
            end
        end)

        if firstTab then firstTab = false Activate() end

        -- ── Element builders ─────────────────────────────────────────────────
        local Tab = {}

        -- Every row in Orca is:
        --   Bold Title   (Tag)
        --   Description text in grey
        --   [optional interactive element on right]
        -- With a thin divider line at the bottom

        local function MakeRow(heightOverride)
            -- Row frame — transparent bg, just divider at bottom
            local row = New("Frame", {
                Size             = UDim2.new(1, 0, 0, heightOverride or 62),
                BackgroundColor3 = C.Content,
                BackgroundTransparency = 0,
                BorderSizePixel  = 0,
                ClipsDescendants = false,
                Parent           = Page,
            })
            -- Bottom divider line
            New("Frame", {
                Size             = UDim2.new(1, 0, 0, 1),
                Position         = UDim2.new(0, 0, 1, -1),
                BackgroundColor3 = C.Divider,
                BorderSizePixel  = 0,
                Parent           = row,
            })
            return row
        end

        -- Title + (Tag) label pair — placed at a Y position inside a row
        local function AddTitleTag(parent, title, tag, y)
            y = y or 10
            -- Main bold title
            local tl = New("TextLabel", {
                Text               = title,
                TextSize           = 15,
                Font               = Enum.Font.GothamBold,
                TextColor3         = C.TxtTitle,
                BackgroundTransparency = 1,
                Size               = UDim2.new(0, 0, 0, 20),
                AutomaticSize      = Enum.AutomaticSize.X,
                Position           = UDim2.new(0, 18, 0, y),
                TextXAlignment     = Enum.TextXAlignment.Left,
                Parent             = parent,
            })

            -- Small (Tag) next to title
            if tag and tag ~= "" then
                -- We use a deferred position so TextBounds is ready
                local tagLbl = New("TextLabel", {
                    Text               = "(" .. tag .. ")",
                    TextSize           = 11,
                    Font               = Enum.Font.Gotham,
                    TextColor3         = C.TxtTag,
                    BackgroundTransparency = 1,
                    Size               = UDim2.new(0, 0, 0, 20),
                    AutomaticSize      = Enum.AutomaticSize.X,
                    Position           = UDim2.new(0, 18, 0, y + 2), -- will be fixed below
                    TextXAlignment     = Enum.TextXAlignment.Left,
                    Parent             = parent,
                })
                -- Fix position once bounds are known
                task.defer(function()
                    tagLbl.Position = UDim2.new(0, 18 + tl.TextBounds.X + 7, 0, y + 2)
                end)
            end
            return tl
        end

        -- Description label
        local function AddDesc(parent, desc, y)
            return New("TextLabel", {
                Text               = desc,
                TextSize           = 12,
                Font               = Enum.Font.Gotham,
                TextColor3         = C.TxtDesc,
                BackgroundTransparency = 1,
                Size               = UDim2.new(1, -90, 0, 0),
                AutomaticSize      = Enum.AutomaticSize.Y,
                Position           = UDim2.new(0, 18, 0, y or 32),
                TextXAlignment     = Enum.TextXAlignment.Left,
                TextWrapped        = true,
                Parent             = parent,
            })
        end

        -- ── TOGGLE ───────────────────────────────────────────────────────────
        function Tab:Toggle(cfg)
            cfg = cfg or {}
            local title = cfg.Title    or "Toggle"
            local tag   = cfg.Tag      or ""
            local desc  = cfg.Desc     or ""
            local def   = cfg.Value;  if def == nil then def = false end
            local cb    = cfg.Callback or function() end

            local on  = def
            local h   = desc ~= "" and 68 or 46
            local row = MakeRow(h)

            local titleY = desc ~= "" and 8 or 13
            AddTitleTag(row, title, tag, titleY)
            if desc ~= "" then AddDesc(row, desc, 30) end

            -- Pill track
            local track = New("Frame", {
                Size             = UDim2.fromOffset(42, 24),
                Position         = UDim2.new(1, -58, 0.5, -12),
                BackgroundColor3 = on and C.PillOn or C.PillOff,
                BorderSizePixel  = 0,
                Parent           = row,
            }, { Corner(12) })
            -- Thumb
            local thumb = New("Frame", {
                Size             = UDim2.fromOffset(18, 18),
                Position         = on and UDim2.fromOffset(21, 3) or UDim2.fromOffset(3, 3),
                BackgroundColor3 = on and C.ThumbOn or C.ThumbOff,
                BorderSizePixel  = 0,
                Parent           = track,
            }, { Corner(9) })

            local function SetState(value, silent)
                on = value
                if value then
                    Tween(track, { BackgroundColor3 = C.PillOn  }, 0.2)
                    Tween(thumb, { Position = UDim2.fromOffset(21, 3), BackgroundColor3 = C.ThumbOn  }, 0.2)
                else
                    Tween(track, { BackgroundColor3 = C.PillOff }, 0.2)
                    Tween(thumb, { Position = UDim2.fromOffset(3,  3), BackgroundColor3 = C.ThumbOff }, 0.2)
                end
                if not silent then task.spawn(cb, value) end
            end
            SetState(def, true) -- apply default silently

            -- Click overlay
            local cl = New("TextButton", {
                Size             = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text             = "",
                AutoButtonColor  = false,
                Parent           = row,
            })
            cl.MouseEnter:Connect(function()    Tween(row, { BackgroundColor3 = C.RowHov }, 0.1) end)
            cl.MouseLeave:Connect(function()    Tween(row, { BackgroundColor3 = C.Content }, 0.1) end)
            cl.MouseButton1Down:Connect(function() Tween(row, { BackgroundColor3 = C.RowPrs }, 0.07) end)
            cl.MouseButton1Up:Connect(function()
                Tween(row, { BackgroundColor3 = C.RowHov }, 0.1)
                SetState(not on)
            end)

            local obj = {}
            function obj:Set(v) SetState(v) end
            function obj:Get() return on end
            return obj
        end

        -- ── BUTTON ───────────────────────────────────────────────────────────
        function Tab:Button(cfg)
            cfg = cfg or {}
            local title = cfg.Title    or "Button"
            local tag   = cfg.Tag      or ""
            local desc  = cfg.Desc     or ""
            local cb    = cfg.Callback or function() end

            local h   = desc ~= "" and 68 or 46
            local row = MakeRow(h)

            local titleY = desc ~= "" and 8 or 13
            AddTitleTag(row, title, tag, titleY)
            if desc ~= "" then AddDesc(row, desc, 30) end

            -- Orca uses a very subtle right chevron
            New("TextLabel", {
                Text               = "›",
                TextSize           = 18,
                Font               = Enum.Font.GothamBold,
                TextColor3         = C.TxtTag,
                BackgroundTransparency = 1,
                Size               = UDim2.fromOffset(24, h),
                Position           = UDim2.new(1, -30, 0, 0),
                TextXAlignment     = Enum.TextXAlignment.Center,
                Parent             = row,
            })

            local cl = New("TextButton", {
                Size             = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text             = "",
                AutoButtonColor  = false,
                Parent           = row,
            })
            cl.MouseEnter:Connect(function()    Tween(row, { BackgroundColor3 = C.RowHov }, 0.1) end)
            cl.MouseLeave:Connect(function()    Tween(row, { BackgroundColor3 = C.Content }, 0.1) end)
            cl.MouseButton1Down:Connect(function() Tween(row, { BackgroundColor3 = C.RowPrs }, 0.07) end)
            cl.MouseButton1Up:Connect(function()
                Tween(row, { BackgroundColor3 = C.RowHov }, 0.1)
                task.spawn(cb)
            end)
        end

        -- ── SLIDER ───────────────────────────────────────────────────────────
        function Tab:Slider(cfg)
            cfg = cfg or {}
            local title   = cfg.Title    or "Slider"
            local tag     = cfg.Tag      or ""
            local desc    = cfg.Desc     or ""
            local sMin    = cfg.Min      or 0
            local sMax    = cfg.Max      or 100
            local sDef    = cfg.Default  or sMin
            local sRound  = cfg.Rounding or 0
            local cb      = cfg.Callback or function() end

            local val   = sDef
            local drag  = false
            local h     = desc ~= "" and 84 or 66
            local row   = MakeRow(h)

            -- Title row — value shown on the right in accent colour
            local titleY = desc ~= "" and 6 or 8
            local tl = New("TextLabel", {
                Text               = title,
                TextSize           = 15,
                Font               = Enum.Font.GothamBold,
                TextColor3         = C.TxtTitle,
                BackgroundTransparency = 1,
                Size               = UDim2.new(0.6, 0, 0, 20),
                Position           = UDim2.new(0, 18, 0, titleY),
                TextXAlignment     = Enum.TextXAlignment.Left,
                Parent             = row,
            })
            if tag ~= "" then
                task.defer(function()
                    New("TextLabel", {
                        Text               = "(" .. tag .. ")",
                        TextSize           = 11,
                        Font               = Enum.Font.Gotham,
                        TextColor3         = C.TxtTag,
                        BackgroundTransparency = 1,
                        Size               = UDim2.new(0, 0, 0, 20),
                        AutomaticSize      = Enum.AutomaticSize.X,
                        Position           = UDim2.new(0, 18 + tl.TextBounds.X + 7, 0, titleY + 2),
                        TextXAlignment     = Enum.TextXAlignment.Left,
                        Parent             = row,
                    })
                end)
            end
            local valLbl = New("TextLabel", {
                Text               = tostring(sDef),
                TextSize           = 13,
                Font               = Enum.Font.GothamBold,
                TextColor3         = C.Accent,
                BackgroundTransparency = 1,
                Size               = UDim2.new(0.25, 0, 0, 20),
                Position           = UDim2.new(0.72, 0, 0, titleY),
                TextXAlignment     = Enum.TextXAlignment.Right,
                Parent             = row,
            })
            if desc ~= "" then AddDesc(row, desc, titleY + 22) end

            -- Track
            local trackY = desc ~= "" and (titleY + 44) or (titleY + 32)
            local trackBg = New("Frame", {
                Size             = UDim2.new(1, -36, 0, 4),
                Position         = UDim2.new(0, 18, 0, trackY),
                BackgroundColor3 = C.PillOff,
                BorderSizePixel  = 0,
                ClipsDescendants = false,
                Parent           = row,
            }, { Corner(2) })
            local fill = New("Frame", {
                Size             = UDim2.new(0, 0, 1, 0),
                BackgroundColor3 = C.Accent,
                BorderSizePixel  = 0,
                Parent           = trackBg,
            }, { Corner(2) })
            -- Thumb circle
            local dot = New("Frame", {
                Size             = UDim2.fromOffset(13, 13),
                AnchorPoint      = Vector2.new(0.5, 0.5),
                Position         = UDim2.new(0, 0, 0.5, 0),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                BorderSizePixel  = 0,
                ZIndex           = 4,
                Parent           = fill,
            }, {
                Corner(7),
                Stroke(C.Accent, 2, 0),
            })

            -- Rounding helper
            local function Rnd(n, f)
                if f == 0 then return math.floor(n + 0.5) end
                return math.floor(n / f + 0.5) * f
            end
            local function SetVal(v)
                val = math.clamp(Rnd(v, sRound), sMin, sMax)
                local pct = (val - sMin) / math.max(sMax - sMin, 0.001)
                Tween(fill, { Size = UDim2.new(pct, 0, 1, 0) }, 0.06)
                valLbl.Text = tostring(val)
                task.spawn(cb, val)
            end
            SetVal(sDef)

            trackBg.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    drag = true
                    local pct = math.clamp((inp.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
                    SetVal(sMin + (sMax - sMin) * pct)
                end
            end)
            UserInputService.InputChanged:Connect(function(inp)
                if drag and inp.UserInputType == Enum.UserInputType.MouseMovement then
                    local pct = math.clamp((inp.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
                    SetVal(sMin + (sMax - sMin) * pct)
                end
            end)
            UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
            end)

            local obj = {}
            function obj:Set(v) SetVal(v) end
            function obj:Get() return val end
            return obj
        end

        -- ── INPUT / TEXTBOX ───────────────────────────────────────────────────
        function Tab:Input(cfg)
            cfg = cfg or {}
            local title     = cfg.Title       or "Input"
            local tag       = cfg.Tag         or ""
            local desc      = cfg.Desc        or ""
            local ph        = cfg.Placeholder or "Type here..."
            local def       = cfg.Default     or ""
            local clearFoc  = cfg.ClearOnFocus
            if clearFoc == nil then clearFoc = false end
            local cb = cfg.Callback or function() end

            local h   = desc ~= "" and 82 or 64
            local row = MakeRow(h)

            local titleY = desc ~= "" and 6 or 8
            AddTitleTag(row, title, tag, titleY)
            if desc ~= "" then AddDesc(row, desc, titleY + 22) end

            local inputY = desc ~= "" and (titleY + 44) or (titleY + 30)
            local ibg = New("Frame", {
                Size             = UDim2.new(1, -36, 0, 24),
                Position         = UDim2.new(0, 18, 0, inputY),
                BackgroundColor3 = C.InputBg,
                BorderSizePixel  = 0,
                Parent           = row,
            }, { Corner(5), Stroke(C.InputBdr, 1, 0) })
            local ibgStroke = ibg:FindFirstChildOfClass("UIStroke")

            local ibox = New("TextBox", {
                Size             = UDim2.new(1, -10, 1, 0),
                Position         = UDim2.new(0, 7, 0, 0),
                BackgroundTransparency = 1,
                Text             = def,
                PlaceholderText  = ph,
                PlaceholderColor3 = C.TxtDim,
                TextSize         = 12,
                Font             = Enum.Font.Gotham,
                TextColor3       = C.TxtTitle,
                TextXAlignment   = Enum.TextXAlignment.Left,
                ClearTextOnFocus = clearFoc,
                Parent           = ibg,
            })
            ibox.Focused:Connect(function()
                Tween(ibg,       { BackgroundColor3 = C.RowHov },   0.12)
                if ibgStroke then Tween(ibgStroke, { Color = C.Accent }, 0.12) end
            end)
            ibox.FocusLost:Connect(function()
                Tween(ibg,       { BackgroundColor3 = C.InputBg }, 0.12)
                if ibgStroke then Tween(ibgStroke, { Color = C.InputBdr }, 0.12) end
                task.spawn(cb, ibox.Text)
            end)
        end

        -- ── DROPDOWN ──────────────────────────────────────────────────────────
        function Tab:Dropdown(cfg)
            cfg = cfg or {}
            local title = cfg.Title    or "Dropdown"
            local tag   = cfg.Tag      or ""
            local desc  = cfg.Desc     or ""
            local list  = cfg.List     or {}
            local def   = cfg.Value    or ""
            local cb    = cfg.Callback or function() end

            local sel   = def
            local open  = false
            local BH    = desc ~= "" and 68 or 46
            local ITEM_H = 28

            -- Outer container (grows when open)
            local outer = New("Frame", {
                Size             = UDim2.new(1, 0, 0, BH),
                BackgroundColor3 = C.Content,
                BorderSizePixel  = 0,
                ClipsDescendants = false,
                Parent           = Page,
            })
            New("Frame", {
                Size             = UDim2.new(1, 0, 0, 1),
                Position         = UDim2.new(0, 0, 1, -1),
                BackgroundColor3 = C.Divider,
                BorderSizePixel  = 0,
                Parent           = outer,
            })

            -- Header (always visible)
            local hdr = New("Frame", {
                Size             = UDim2.new(1, 0, 0, BH),
                BackgroundTransparency = 1,
                ClipsDescendants = true,
                Parent           = outer,
            })
            local titleY = desc ~= "" and 8 or 13
            AddTitleTag(hdr, title, tag, titleY)
            if desc ~= "" then AddDesc(hdr, desc, 30) end

            local selLbl = New("TextLabel", {
                Text               = sel ~= "" and sel or "Select...",
                TextSize           = 12,
                Font               = Enum.Font.Gotham,
                TextColor3         = C.TxtDesc,
                BackgroundTransparency = 1,
                Size               = UDim2.new(0.3, 0, 0, BH),
                Position           = UDim2.new(0.65, 0, 0, 0),
                TextXAlignment     = Enum.TextXAlignment.Right,
                Parent             = hdr,
            })
            local arrow = New("TextLabel", {
                Text               = "›",
                TextSize           = 15,
                Font               = Enum.Font.GothamBold,
                TextColor3         = C.TxtTag,
                BackgroundTransparency = 1,
                Size               = UDim2.new(0, 24, 0, BH),
                Position           = UDim2.new(1, -28, 0, 0),
                TextXAlignment     = Enum.TextXAlignment.Center,
                Rotation           = 90,
                Parent             = hdr,
            })

            -- Dropdown panel
            local panel = New("Frame", {
                Size             = UDim2.new(1, 0, 0, 0),
                Position         = UDim2.new(0, 0, 0, BH),
                BackgroundColor3 = C.RowHov,
                BorderSizePixel  = 0,
                ClipsDescendants = true,
                ZIndex           = 10,
                Parent           = outer,
            }, { Corner(0), Pad(3, 3, 6, 6), List(2) })

            local function CalcH() return math.min(#list * ITEM_H + 6, 160) end

            local function BuildList()
                for _, v in ipairs(panel:GetChildren()) do
                    if v:IsA("TextButton") then v:Destroy() end
                end
                for _, opt in ipairs(list) do
                    local isSel = opt == sel
                    local btn = New("TextButton", {
                        Text             = opt,
                        TextSize         = 12,
                        Font             = isSel and Enum.Font.GothamBold or Enum.Font.Gotham,
                        TextColor3       = isSel and C.Accent or C.TxtDesc,
                        BackgroundColor3 = isSel and C.AccentDim or C.RowHov,
                        Size             = UDim2.new(1, 0, 0, ITEM_H - 2),
                        AutoButtonColor  = false,
                        TextXAlignment   = Enum.TextXAlignment.Left,
                        ZIndex           = 11,
                        Parent           = panel,
                    }, { Corner(4), Pad(0, 0, 8, 0) })
                    btn.MouseEnter:Connect(function()
                        if opt ~= sel then Tween(btn, { BackgroundColor3 = C.RowPrs }, 0.1) end
                    end)
                    btn.MouseLeave:Connect(function()
                        if opt ~= sel then Tween(btn, { BackgroundColor3 = C.RowHov }, 0.1) end
                    end)
                    btn.MouseButton1Click:Connect(function()
                        sel = opt
                        selLbl.Text = opt
                        BuildList()
                        task.spawn(cb, opt)
                    end)
                end
            end
            BuildList()

            local function SetOpen(state)
                open = state
                local targetH = state and CalcH() or 0
                Tween(panel, { Size = UDim2.new(1, 0, 0, targetH) }, 0.18)
                Tween(outer, { Size = UDim2.new(1, 0, 0, BH + (state and targetH or 0)) }, 0.18)
                Tween(arrow, { Rotation = state and 270 or 90 }, 0.18)
            end

            local hClick = New("TextButton", {
                Size             = UDim2.new(1, 0, 0, BH),
                BackgroundTransparency = 1,
                Text             = "",
                AutoButtonColor  = false,
                Parent           = hdr,
            })
            hClick.MouseButton1Click:Connect(function() SetOpen(not open) end)
            hClick.MouseEnter:Connect(function() Tween(outer, { BackgroundColor3 = C.RowHov }, 0.1) end)
            hClick.MouseLeave:Connect(function() Tween(outer, { BackgroundColor3 = C.Content }, 0.1) end)

            local obj = { Value = sel }
            function obj:UpdateList(l)
                list = l BuildList()
                if open then
                    local h = CalcH()
                    Tween(panel, { Size = UDim2.new(1, 0, 0, h) }, 0.15)
                    Tween(outer, { Size = UDim2.new(1, 0, 0, BH + h) }, 0.15)
                end
            end
            function obj:SetValue(v) sel = v selLbl.Text = v ~= "" and v or "Select..." obj.Value = v BuildList() end
            function obj:GetValue() return sel end
            return obj
        end

        -- ── LABEL — read-only info row ─────────────────────────────────────────
        function Tab:Label(cfg)
            cfg = cfg or {}
            local title = cfg.Title or "Info"
            local tag   = cfg.Tag   or ""
            local desc  = cfg.Desc  or ""

            local row = MakeRow(desc ~= "" and 68 or 46)
            local titleY = desc ~= "" and 8 or 13
            AddTitleTag(row, title, tag, titleY)

            local descLbl
            if desc ~= "" then
                descLbl = AddDesc(row, desc, 30)
            else
                descLbl = New("TextLabel", {
                    Text               = "—",
                    TextSize           = 12,
                    Font               = Enum.Font.Gotham,
                    TextColor3         = C.TxtDesc,
                    BackgroundTransparency = 1,
                    Size               = UDim2.new(1, -90, 0, 16),
                    Position           = UDim2.new(0, 18, 0, 30),
                    TextXAlignment     = Enum.TextXAlignment.Left,
                    TextWrapped        = true,
                    Parent             = row,
                })
            end

            local obj = {}
            function obj:Set(text)
                descLbl.Text = tostring(text)
            end
            return obj
        end

        -- ── DIVIDER ────────────────────────────────────────────────────────────
        function Tab:Divider()
            New("Frame", {
                Size             = UDim2.new(1, 0, 0, 10),
                BackgroundTransparency = 1,
                Parent           = Page,
            })
        end

        return Tab
    end

    function Win:Notify(cfg) ShowNotify(cfg) end

    return Win
end

return DaggerLib
