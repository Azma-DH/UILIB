-- ─── Tween ───────────────────────────────────────────────────────────────────
local function tw(o, p, t, s, d)
	TS:Create(o, TweenInfo.new(t or 0.2, s or Enum.EasingStyle.Quint, d or Enum.EasingDirection.Out), p):Play()
end

-- ─── Instance ────────────────────────────────────────────────────────────────
local function mk(cls, props, kids)
	local o = Instance.new(cls)
	for k,v in pairs(props or {}) do o[k]=v end
	for _,v in pairs(kids  or {}) do v.Parent=o end
	return o
end

local function rnd(r) return mk("UICorner",{CornerRadius=UDim.new(0,r or 6)}) end
local function str(c,th,tr) return mk("UIStroke",{Color=c or C.Border,Thickness=th or 1,Transparency=tr or 0}) end
local function lst(p) return mk("UIListLayout",{Padding=UDim.new(0,p or 0),SortOrder=Enum.SortOrder.LayoutOrder}) end
local function pdg(t,b,l,r) return mk("UIPadding",{PaddingTop=UDim.new(0,t or 0),PaddingBottom=UDim.new(0,b or 0),PaddingLeft=UDim.new(0,l or 0),PaddingRight=UDim.new(0,r or 0)}) end

